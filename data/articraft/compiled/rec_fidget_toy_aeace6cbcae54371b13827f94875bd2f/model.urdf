    <collision name="weight_disk">
      <origin xyz="0 0 0.0009" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0082" length="0.0018" />
        </geometry>
      </collision>
    </link>
  <joint name="hub_to_wing" type="continuous">
    <parent link="center_hub" />
    <child link="wing_body" />
    <axis xyz="0 0 1" />
    <limit effort="0.25" velocity="80" />
    <dynamics damping="0.002" friction="0.0005" />
    </joint>
  <joint name="wing_to_weight_0" type="fixed">
    <origin xyz="0.0405 -0.0055 0.00325" rpy="0 0 0" />
    <parent link="wing_body" />
    <child link="weight_0" />
    </joint>
  <joint name="wing_to_weight_1" type="fixed">
    <origin xyz="-0.0405 0.0055 0.00325" rpy="0 0 0" />
    <parent link="wing_body" />
    <child link="weight_1" />
    </joint>
  </robot>
