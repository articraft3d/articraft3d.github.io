<robot name="bi_wing_fidget_spinner">
  <link name="center_hub">
    <visual name="top_cap">
      <origin xyz="0 0 0.00625" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0175" length="0.0025" />
        </geometry>
      <material name="brushed_steel">
        <color rgba="0.72 0.72 0.68 1" />
        </material>
      </visual>
    <visual name="bottom_cap">
      <origin xyz="0 0 -0.00625" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0175" length="0.0025" />
        </geometry>
      <material name="brushed_steel">
        <color rgba="0.72 0.72 0.68 1" />
        </material>
      </visual>
    <visual name="inner_race">
      <geometry>
        <cylinder radius="0.0105" length="0.01" />
        </geometry>
      <material name="dark_bearing_rubber">
        <color rgba="0.015 0.017 0.02 1" />
        </material>
      </visual>
    <collision name="top_cap">
      <origin xyz="0 0 0.00625" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0175" length="0.0025" />
        </geometry>
      </collision>
    <collision name="bottom_cap">
      <origin xyz="0 0 -0.00625" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0175" length="0.0025" />
        </geometry>
      </collision>
    <collision name="inner_race">
      <geometry>
        <cylinder radius="0.0105" length="0.01" />
        </geometry>
      </collision>
    </link>
  <link name="wing_body">
    <visual name="wing_shell">
      <geometry>
        <mesh filename="assets/meshes/wing_shell.obj" />
        </geometry>
      <material name="satin_blue_plastic">
        <color rgba="0.05 0.28 0.82 1" />
        </material>
      </visual>
    <visual name="front_root_blend">
      <origin xyz="0.024 -0.006 0" rpy="0 0 -0.22" />
      <geometry>
        <box size="0.016 0.028 0.008" />
        </geometry>
      <material name="satin_blue_plastic">
        <color rgba="0.05 0.28 0.82 1" />
        </material>
      </visual>
    <visual name="rear_root_blend">
      <origin xyz="-0.024 0.006 0" rpy="0 0 -0.22" />
      <geometry>
        <box size="0.016 0.028 0.008" />
        </geometry>
      <material name="satin_blue_plastic">
        <color rgba="0.05 0.28 0.82 1" />
        </material>
      </visual>
    <collision name="wing_shell">
      <geometry>
        <mesh filename="assets/meshes/wing_shell.obj" />
        </geometry>
      </collision>
    <collision name="front_root_blend">
      <origin xyz="0.024 -0.006 0" rpy="0 0 -0.22" />
      <geometry>
        <box size="0.016 0.028 0.008" />
        </geometry>
      </collision>
    <collision name="rear_root_blend">
      <origin xyz="-0.024 0.006 0" rpy="0 0 -0.22" />
      <geometry>
        <box size="0.016 0.028 0.008" />
        </geometry>
      </collision>
    </link>
  <link name="weight_0">
    <visual name="pocket_rim">
      <geometry>
        <mesh filename="assets/meshes/pocket_rim_0.obj" />
        </geometry>
      <material name="dark_bearing_rubber">
        <color rgba="0.015 0.017 0.02 1" />
        </material>
      </visual>
    <visual name="weight_disk">
      <origin xyz="0 0 0.0009" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0082" length="0.0018" />
        </geometry>
      <material name="brass_weights">
        <color rgba="0.92 0.66 0.24 1" />
        </material>
      </visual>
    <collision name="pocket_rim">
      <geometry>
        <mesh filename="assets/meshes/pocket_rim_0.obj" />
        </geometry>
      </collision>
    <collision name="weight_disk">
      <origin xyz="0 0 0.0009" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0082" length="0.0018" />
        </geometry>
      </collision>
    </link>
  <link name="weight_1">
    <visual name="pocket_rim">
      <geometry>
        <mesh filename="assets/meshes/pocket_rim_1.obj" />
        </geometry>
      <material name="dark_bearing_rubber">
        <color rgba="0.015 0.017 0.02 1" />
        </material>
      </visual>
    <visual name="weight_disk">
      <origin xyz="0 0 0.0009" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0082" length="0.0018" />
        </geometry>
      <material name="brass_weights">
        <color rgba="0.92 0.66 0.24 1" />
        </material>
      </visual>
    <collision name="pocket_rim">
      <geometry>
        <mesh filename="assets/meshes/pocket_rim_1.obj" />
        </geometry>
