  <joint name="base_to_head" type="revolute">
    <origin xyz="0 0 1.02" rpy="0 0 0" />
    <parent link="base" />
    <child link="head" />
    <axis xyz="0 -1 0" />
    <limit effort="180" velocity="0.65" lower="-0.45" upper="0.55" />
    <dynamics damping="4" friction="1.5" />
    </joint>
  <joint name="head_to_rotor" type="continuous">
    <origin xyz="0 0 0" rpy="0 1.5708 0" />
