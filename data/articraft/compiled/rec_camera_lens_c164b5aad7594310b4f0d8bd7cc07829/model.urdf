<robot name="cine_zoom_lens">
  <material name="black_anodized">
    <color rgba="0.01 0.012 0.014 1" />
    </material>
  <material name="dark_alloy">
    <color rgba="0.06 0.065 0.07 1" />
    </material>
  <material name="satin_alloy">
    <color rgba="0.42 0.43 0.4 1" />
    </material>
  <material name="rubber_black">
    <color rgba="0.015 0.015 0.013 1" />
    </material>
  <material name="iris_blue">
    <color rgba="0.07 0.13 0.2 1" />
    </material>
  <material name="green_coated_glass">
    <color rgba="0.12 0.42 0.36 0.52" />
    </material>
  <material name="engraved_white">
    <color rgba="0.92 0.9 0.82 1" />
    </material>
  <link name="barrel">
    <visual name="alloy_barrel">
      <geometry>
        <mesh filename="assets/meshes/alloy_barrel.obj" />
        </geometry>
      <material name="dark_alloy">
        <color rgba="0.06 0.065 0.07 1" />
        </material>
      </visual>
    <visual name="zoom_index">
      <origin xyz="-0.062 0 0.0895" rpy="0 0 0" />
      <geometry>
        <box size="0.006 0.026 0.0022" />
        </geometry>
      <material name="engraved_white">
        <color rgba="0.92 0.9 0.82 1" />
        </material>
      </visual>
    <visual name="iris_index">
      <origin xyz="0.145 0 0.0868" rpy="0 0 0" />
      <geometry>
        <box size="0.005 0.02 0.0022" />
        </geometry>
      <material name="engraved_white">
        <color rgba="0.92 0.9 0.82 1" />
        </material>
      </visual>
    <visual name="zoom_bearings">
      <geometry>
        <mesh filename="assets/meshes/zoom_bearings.obj" />
        </geometry>
      <material name="satin_alloy">
        <color rgba="0.42 0.43 0.4 1" />
        </material>
      </visual>
    <visual name="iris_bearings">
      <geometry>
        <mesh filename="assets/meshes/iris_bearings.obj" />
        </geometry>
      <material name="satin_alloy">
        <color rgba="0.42 0.43 0.4 1" />
        </material>
      </visual>
    <collision name="alloy_barrel">
      <geometry>
        <mesh filename="assets/meshes/alloy_barrel.obj" />
        </geometry>
      </collision>
    <collision name="zoom_index">
      <origin xyz="-0.062 0 0.0895" rpy="0 0 0" />
      <geometry>
        <box size="0.006 0.026 0.0022" />
        </geometry>
      </collision>
    <collision name="iris_index">
      <origin xyz="0.145 0 0.0868" rpy="0 0 0" />
      <geometry>
        <box size="0.005 0.02 0.0022" />
        </geometry>
      </collision>
    <collision name="zoom_bearings">
      <geometry>
        <mesh filename="assets/meshes/zoom_bearings.obj" />
        </geometry>
      </collision>
    <collision name="iris_bearings">
      <geometry>
        <mesh filename="assets/meshes/iris_bearings.obj" />
        </geometry>
      </collision>
    </link>
  <link name="zoom_ring">
    <visual name="zoom_t_ring">
      <geometry>
        <mesh filename="assets/meshes/zoom_t_ring.obj" />
        </geometry>
      <material name="rubber_black">
        <color rgba="0.015 0.015 0.013 1" />
        </material>
      </visual>
    <collision name="zoom_t_ring">
      <geometry>
        <mesh filename="assets/meshes/zoom_t_ring.obj" />
        </geometry>
      </collision>
    </link>
  <link name="iris_ring">
    <visual name="iris_aperture_ring">
      <geometry>
        <mesh filename="assets/meshes/iris_aperture_ring.obj" />
        </geometry>
      <material name="iris_blue">
        <color rgba="0.07 0.13 0.2 1" />
        </material>
      </visual>
    <collision name="iris_aperture_ring">
      <geometry>
        <mesh filename="assets/meshes/iris_aperture_ring.obj" />
        </geometry>
      </collision>
    </link>
  <link name="inner_barrel">
    <visual name="inner_front_barrel">
      <geometry>
        <mesh filename="assets/meshes/inner_front_barrel.obj" />
        </geometry>
      <material name="black_anodized">
        <color rgba="0.01 0.012 0.014 1" />
        </material>
      </visual>
    <visual name="slide_bearings">
      <geometry>
        <mesh filename="assets/meshes/slide_bearings.obj" />
        </geometry>
      <material name="satin_alloy">
        <color rgba="0.42 0.43 0.4 1" />
        </material>
      </visual>
    <visual name="focus_bearings">
      <geometry>
        <mesh filename="assets/meshes/focus_bearings.obj" />
        </geometry>
      <material name="satin_alloy">
        <color rgba="0.42 0.43 0.4 1" />
        </material>
      </visual>
    <visual name="front_glass">
      <geometry>
        <mesh filename="assets/meshes/front_glass.obj" />
        </geometry>
      <material name="green_coated_glass">
        <color rgba="0.12 0.42 0.36 0.52" />
        </material>
      </visual>
    <collision name="inner_front_barrel">
      <geometry>
        <mesh filename="assets/meshes/inner_front_barrel.obj" />
        </geometry>
      </collision>
    <collision name="slide_bearings">
      <geometry>
        <mesh filename="assets/meshes/slide_bearings.obj" />
        </geometry>
      </collision>
    <collision name="focus_bearings">
      <geometry>
        <mesh filename="assets/meshes/focus_bearings.obj" />
        </geometry>
      </collision>
    <collision name="front_glass">
      <geometry>
        <mesh filename="assets/meshes/front_glass.obj" />
        </geometry>
      </collision>
    </link>
  <link name="focus_ring">
    <visual name="focus_ring_grip">
      <geometry>
        <mesh filename="assets/meshes/focus_ring_grip.obj" />
        </geometry>
      <material name="satin_alloy">
        <color rgba="0.42 0.43 0.4 1" />
        </material>
      </visual>
    <collision name="focus_ring_grip">
      <geometry>
        <mesh filename="assets/meshes/focus_ring_grip.obj" />
        </geometry>
      </collision>
    </link>
  <joint name="barrel_to_zoom_ring" type="revolute">
    <origin xyz="-0.055 0 0" rpy="0 0 0" />
    <parent link="barrel" />
    <child link="zoom_ring" />
    <axis xyz="1 0 0" />
    <limit effort="2.5" velocity="1.5" lower="0" upper="1.25" />
    </joint>
  <joint name="barrel_to_inner_barrel" type="prismatic">
    <origin xyz="0.065 0 0" rpy="0 0 0" />
    <parent link="barrel" />
    <child link="inner_barrel" />
    <axis xyz="1 0 0" />
    <limit effort="18" velocity="0.08" lower="0" upper="0.032" />
    </joint>
  <joint name="barrel_to_iris_ring" type="revolute">
    <origin xyz="0.105 0 0" rpy="0 0 0" />
    <parent link="barrel" />
    <child link="iris_ring" />
    <axis xyz="1 0 0" />
    <limit effort="1.2" velocity="1.4" lower="0" upper="1.1" />
    </joint>
  <joint name="inner_barrel_to_focus_ring" type="revolute">
    <origin xyz="0.16 0 0" rpy="0 0 0" />
    <parent link="inner_barrel" />
    <child link="focus_ring" />
    <axis xyz="1 0 0" />
    <limit effort="1.5" velocity="1.2" lower="-2.35" upper="2.35" />
    </joint>
  </robot>
