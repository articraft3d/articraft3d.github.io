  <joint name="rail_to_car" type="prismatic">
    <origin xyz="0 0 0.12" rpy="0 0 0" />
    <parent link="guide_rail" />
    <child link="car" />
    <axis xyz="0 0 1" />
    <limit effort="9000" velocity="1.2" lower="0" upper="3.35" />
    </joint>
  <joint name="car_to_door" type="prismatic">
    <parent link="car" />
    <child link="door" />
    <axis xyz="1 0 0" />
    <limit effort="180" velocity="0.45" lower="0" upper="0.44" />
    </joint>
  <joint name="car_to_handrail" type="revolute">
    <origin xyz="0 0.72 1.12" rpy="0 0 0" />
    <parent link="car" />
    <child link="handrail" />
    <axis xyz="1 0 0" />
    <limit effort="20" velocity="0.8" lower="-0.18" upper="0.18" />
    </joint>
  </robot>
