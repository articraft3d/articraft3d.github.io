  <link name="nose_latch">
    <visual name="hooked_leaf">
      <geometry>
        <mesh filename="assets/meshes/nose_latch_hooked_leaf.obj" />
        </geometry>
      <material name="brass_pin">
        <color rgba="0.85 0.63 0.23 1" />
        </material>
      </visual>
