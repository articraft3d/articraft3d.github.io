  <joint name="guide_to_plunger" type="prismatic">
    <origin xyz="0.42 0 0" rpy="0 0 0" />
    <parent link="guide_tube" />
    <child link="plunger" />
    <axis xyz="1 0 0" />
    <limit effort="80" velocity="0.35" lower="0" upper="0.1" />
    </joint>
  <joint name="plunger_to_nose_latch" type="revolute">
    <parent link="plunger" />
    <child link="nose_latch" />
    <axis xyz="0 -1 0" />
    <limit effort="2" velocity="5" lower="-0.35" upper="1.05" />
    </joint>
  </robot>
