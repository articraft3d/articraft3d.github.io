      <material name="cool_filter">
        <color rgba="0.25 0.55 0.95 0.45" />
        </material>
      </visual>
    </link>
  <joint name="stand_to_yoke" type="revolute">
    <origin xyz="0 0 0.34" rpy="0 0 0" />
    <parent link="stand" />
    <child link="yoke" />
    <axis xyz="0 0 1" />
    <limit effort="8" velocity="2" lower="-3.14159" upper="3.14159" />
    </joint>
  <joint name="yoke_to_can" type="revolute">
    <origin xyz="0.02 0 0.11" rpy="0 0 0" />
    <parent link="yoke" />
    <child link="can" />
    <axis xyz="0 1 0" />
    <limit effort="6" velocity="1.8" lower="-0.85" upper="0.85" />
    </joint>
  <joint name="can_to_filter_holder" type="revolute">
    <origin xyz="0.111 0 -0.06" rpy="0 0 0" />
    <parent link="can" />
    <child link="filter_holder" />
    <axis xyz="0 1 0" />
    <limit effort="1" velocity="2.2" lower="0" upper="1.35" />
    </joint>
  </robot>
