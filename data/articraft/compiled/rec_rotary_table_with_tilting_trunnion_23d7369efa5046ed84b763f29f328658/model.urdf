  <joint name="access_cover_0_mount" type="fixed">
    <origin xyz="-0.5985 0 0.45" rpy="0 0 0" />
    <parent link="base_frame" />
    <child link="access_cover_0" />
    </joint>
  <joint name="access_cover_1_mount" type="fixed">
    <origin xyz="0.5985 0 0.45" rpy="0 0 0" />
    <parent link="base_frame" />
    <child link="access_cover_1" />
    </joint>
  <joint name="trunnion_tilt" type="revolute">
    <origin xyz="0 0 0.45" rpy="0 0 0" />
    <parent link="base_frame" />
    <child link="trunnion_cradle" />
    <axis xyz="1 0 0" />
    <limit effort="1500" velocity="0.55" lower="-0.959931" upper="0.959931" />
    </joint>
  <joint name="table_spin" type="continuous">
    <parent link="trunnion_cradle" />
    <child link="rotary_table" />
    <axis xyz="0 0 1" />
    <limit effort="900" velocity="2.5" />
    </joint>
  </robot>
