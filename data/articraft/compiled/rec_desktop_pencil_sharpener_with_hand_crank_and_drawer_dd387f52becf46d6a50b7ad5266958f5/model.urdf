<robot name="vintage_desktop_pencil_sharpener">
  <material name="cast_green">
    <color rgba="0.1 0.24 0.18 1" />
    </material>
  <material name="dark_shadow">
    <color rgba="0.01 0.01 0.009 1" />
    </material>
  <material name="brushed_steel">
    <color rgba="0.62 0.64 0.61 1" />
    </material>
  <material name="dull_nickel">
    <color rgba="0.38 0.4 0.39 1" />
    </material>
  <material name="drawer_metal">
    <color rgba="0.3 0.32 0.31 1" />
    </material>
  <material name="warm_wood">
    <color rgba="0.55 0.32 0.15 1" />
    </material>
  <material name="black_rubber">
    <color rgba="0.025 0.025 0.023 1" />
    </material>
  <link name="housing">
    <visual name="cast_shell">
      <geometry>
        <mesh filename="assets/meshes/cast_housing.obj" />
        </geometry>
      <material name="cast_green" />
      </visual>
    <visual name="port_depth_shadow">
      <origin xyz="0.034 0 0.108" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.0165" length="0.004" />
        </geometry>
      <material name="dark_shadow" />
      </visual>
    <collision name="cast_shell">
      <geometry>
        <mesh filename="assets/meshes/cast_housing.obj" />
        </geometry>
      </collision>
    <collision name="port_depth_shadow">
      <origin xyz="0.034 0 0.108" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.0165" length="0.004" />
        </geometry>
      </collision>
    </link>
  <link name="drawer">
    <visual name="drawer_tray">
      <geometry>
        <mesh filename="assets/meshes/shavings_drawer.obj" />
        </geometry>
      <material name="drawer_metal" />
      </visual>
    <visual name="drawer_pull">
      <origin xyz="-0.012 0 -0.003" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.006" length="0.036" />
        </geometry>
      <material name="black_rubber" />
      </visual>
    <collision name="drawer_tray">
      <geometry>
        <mesh filename="assets/meshes/shavings_drawer.obj" />
        </geometry>
      </collision>
    <collision name="drawer_pull">
      <origin xyz="-0.012 0 -0.003" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.006" length="0.036" />
        </geometry>
      </collision>
    </link>
  <link name="crank">
    <visual name="shaft">
      <origin xyz="0.02 0 0" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.0105" length="0.04" />
        </geometry>
      <material name="brushed_steel" />
      </visual>
    <visual name="hub">
      <origin xyz="0.043 0 0" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.018" length="0.008" />
        </geometry>
      <material name="dull_nickel" />
      </visual>
    <visual name="crank_arm">
      <origin xyz="0.046 0 0.037" rpy="0 0 0" />
      <geometry>
        <box size="0.007 0.012 0.07" />
        </geometry>
      <material name="brushed_steel" />
      </visual>
    <visual name="handle_post">
      <origin xyz="0.06 0 0.074" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.006" length="0.028" />
        </geometry>
      <material name="brushed_steel" />
      </visual>
    <visual name="wood_grip">
      <origin xyz="0.082 0 0.074" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.011" length="0.036" />
        </geometry>
      <material name="warm_wood" />
      </visual>
    <collision name="shaft">
      <origin xyz="0.02 0 0" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.0105" length="0.04" />
        </geometry>
      </collision>
    <collision name="hub">
      <origin xyz="0.043 0 0" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.018" length="0.008" />
        </geometry>
      </collision>
    <collision name="crank_arm">
      <origin xyz="0.046 0 0.037" rpy="0 0 0" />
      <geometry>
        <box size="0.007 0.012 0.07" />
        </geometry>
      </collision>
    <collision name="handle_post">
      <origin xyz="0.06 0 0.074" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.006" length="0.028" />
        </geometry>
      </collision>
    <collision name="wood_grip">
      <origin xyz="0.082 0 0.074" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.011" length="0.036" />
        </geometry>
      </collision>
    </link>
  <link name="selector">
    <visual name="thumb_tab">
      <origin xyz="-0.007 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.008 0.014 0.016" />
        </geometry>
      <material name="dull_nickel" />
      </visual>
    <visual name="guide_pin">
      <origin xyz="0 0 0" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.005" length="0.018" />
        </geometry>
      <material name="brushed_steel" />
      </visual>
    <collision name="thumb_tab">
      <origin xyz="-0.007 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.008 0.014 0.016" />
        </geometry>
      </collision>
    <collision name="guide_pin">
      <origin xyz="0 0 0" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.005" length="0.018" />
        </geometry>
      </collision>
    </link>
  <joint name="drawer_slide" type="prismatic">
    <origin xyz="-0.094 0 0.045" rpy="0 0 0" />
    <parent link="housing" />
    <child link="drawer" />
    <axis xyz="-1 0 0" />
    <limit effort="18" velocity="0.25" lower="0" upper="0.065" />
    </joint>
  <joint name="crank_spin" type="continuous">
    <origin xyz="0.09 0 0.108" rpy="0 0 0" />
    <parent link="housing" />
    <child link="crank" />
    <axis xyz="1 0 0" />
    <limit effort="2.5" velocity="8" />
    </joint>
  <joint name="selector_slide" type="prismatic">
    <origin xyz="-0.095 -0.04 0.091" rpy="0 0 0" />
    <parent link="housing" />
    <child link="selector" />
    <axis xyz="0 0 1" />
    <limit effort="3" velocity="0.12" lower="0" upper="0.028" />
    </joint>
  </robot>
