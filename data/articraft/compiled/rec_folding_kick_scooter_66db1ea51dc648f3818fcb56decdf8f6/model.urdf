  <joint name="deck_to_handlebar" type="revolute">
    <origin xyz="0.27 0 0.143" rpy="0 0 0" />
    <parent link="deck" />
    <child link="handlebar" />
    <axis xyz="0 -1 0" />
    <limit effort="18" velocity="1.5" lower="0" upper="1.35" />
    <dynamics damping="0.25" friction="0.05" />
    </joint>
  <joint name="deck_to_front_fork" type="revolute">
    <origin xyz="0.365 0 0.125" rpy="0 0 0" />
    <parent link="deck" />
    <child link="front_fork" />
    <axis xyz="1 0 0" />
    <limit effort="10" velocity="2" lower="-0.35" upper="0.35" />
    <dynamics damping="0.15" friction="0.03" />
    </joint>
