    <origin xyz="0 0.247 0.29" rpy="0 0 0" />
    <parent link="bowl" />
    <child link="lid" />
    <axis xyz="-1 0 0" />
    <limit effort="8" velocity="2" lower="0" upper="1.55" />
    </joint>
