  <joint name="base_to_bowl" type="fixed">
    <parent link="base" />
    <child link="bowl" />
    </joint>
  <joint name="bowl_to_cutter_disc" type="continuous">
    <origin xyz="0 0 0.184" rpy="0 0 0" />
    <parent link="bowl" />
    <child link="cutter_disc" />
    <axis xyz="0 0 1" />
    <limit effort="2" velocity="40" />
    </joint>
