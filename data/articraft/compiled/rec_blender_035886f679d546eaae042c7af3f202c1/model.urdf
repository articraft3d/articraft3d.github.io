  <joint name="housing_to_chamber_cup" type="revolute">
    <origin xyz="0 -0.02 0.565" rpy="0 0 0" />
    <parent link="housing" />
    <child link="chamber_cup" />
    <axis xyz="0 0 1" />
    <limit effort="8" velocity="1.2" lower="0" upper="0.42" />
    </joint>
  <joint name="cup_to_lid_hinge" type="fixed">
    <parent link="chamber_cup" />
    <child link="lid_hinge" />
    </joint>
  <joint name="hinge_to_lid" type="revolute">
    <origin xyz="0 0.088 0.268" rpy="0 0 0" />
    <parent link="lid_hinge" />
    <child link="chamber_lid" />
    <axis xyz="-1 0 0" />
    <limit effort="4" velocity="1.4" lower="0" upper="1.25" />
    </joint>
  <joint name="cup_to_blade" type="continuous">
    <origin xyz="0 0 0.052" rpy="0 0 0" />
    <parent link="chamber_cup" />
    <child link="blade_drive" />
    <axis xyz="0 0 1" />
    <limit effort="2" velocity="80" />
    </joint>
  <joint name="housing_to_speed_dial" type="revolute">
    <origin xyz="0 -0.166 0.325" rpy="1.5708 0 0" />
    <parent link="housing" />
    <child link="speed_dial" />
    <axis xyz="0 0 1" />
    <limit effort="0.25" velocity="4" lower="0" upper="4.7" />
    </joint>
  <joint name="housing_to_status_light" type="fixed">
    <origin xyz="-0.065 -0.166 0.405" rpy="1.5708 0 0" />
    <parent link="housing" />
    <child link="status_light" />
    </joint>
  </robot>
