  <joint name="arm_to_ring" type="revolute">
    <parent link="wall_arm" />
    <child link="meridian_ring" />
    <axis xyz="0 1 0" />
    <limit effort="12" velocity="1.4" lower="-0.65" upper="0.65" />
    </joint>
  <joint name="ring_to_globe" type="continuous">
    <origin xyz="0.255 0 0" rpy="0 0 0" />
    <parent link="meridian_ring" />
    <child link="globe" />
    <axis xyz="0 0 1" />
    <limit effort="2" velocity="4" />
    </joint>
  </robot>
