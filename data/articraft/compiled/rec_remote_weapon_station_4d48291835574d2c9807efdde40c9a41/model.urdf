  <joint name="base_yaw" type="revolute">
    <origin xyz="0 0 0.24" rpy="0 0 0" />
    <parent link="pedestal" />
    <child link="turret" />
    <axis xyz="0 0 1" />
    <limit effort="450" velocity="1.2" lower="-3.14159" upper="3.14159" />
    </joint>
  <joint name="weapon_pitch" type="revolute">
    <origin xyz="0.05 0 0.28" rpy="0 0 0" />
    <parent link="turret" />
    <child link="weapon_cradle" />
    <axis xyz="0 -1 0" />
    <limit effort="220" velocity="0.9" lower="-0.25" upper="0.85" />
    </joint>
  <joint name="mast_mount" type="fixed">
    <origin xyz="-0.19 0.39 0.14" rpy="0 0 0" />
    <parent link="turret" />
    <child link="sensor_mast" />
    </joint>
  <joint name="sensor_tilt" type="revolute">
    <origin xyz="0.3 0 0.34" rpy="0 0 0" />
    <parent link="sensor_mast" />
    <child link="sensor_pod" />
    <axis xyz="0 -1 0" />
    <limit effort="35" velocity="1.4" lower="-0.45" upper="0.75" />
    </joint>
  </robot>
