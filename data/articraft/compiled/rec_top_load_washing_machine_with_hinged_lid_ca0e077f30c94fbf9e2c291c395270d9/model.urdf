  <joint name="lid_hinge" type="revolute">
    <origin xyz="0 0.285 0.945" rpy="0 0 -1.5708" />
    <parent link="cabinet" />
    <child link="lid" />
    <axis xyz="0 -1 0" />
    <limit effort="35" velocity="1.6" lower="0" upper="1.85" />
    </joint>
  <joint name="basket_spin" type="continuous">
    <origin xyz="0 -0.045 0.33" rpy="0 0 0" />
    <parent link="cabinet" />
    <child link="basket" />
    <axis xyz="0 0 1" />
    <limit effort="45" velocity="18" />
    </joint>
  <joint name="cycle_knob_spin" type="continuous">
    <origin xyz="0 0.35 1.07" rpy="-1.5708 0 0" />
    <parent link="cabinet" />
    <child link="cycle_knob" />
    <axis xyz="0 0 1" />
    <limit effort="2" velocity="8" />
    </joint>
  <joint name="start_button_press" type="prismatic">
    <origin xyz="-0.125 0.35 0.995" rpy="0 0 0" />
    <parent link="cabinet" />
    <child link="start_button" />
    <axis xyz="0 1 0" />
    <limit effort="8" velocity="0.35" lower="0" upper="0.012" />
    </joint>
  <joint name="cancel_button_press" type="prismatic">
    <origin xyz="0.125 0.35 0.995" rpy="0 0 0" />
    <parent link="cabinet" />
    <child link="cancel_button" />
    <axis xyz="0 1 0" />
    <limit effort="8" velocity="0.35" lower="0" upper="0.012" />
    </joint>
  <joint name="bleach_cap_spin" type="continuous">
    <origin xyz="-0.16 0.22 0.947" rpy="0 0 0" />
    <parent link="cabinet" />
    <child link="bleach_cap" />
    <axis xyz="0 0 1" />
    <limit effort="1.5" velocity="6" />
    </joint>
  </robot>
