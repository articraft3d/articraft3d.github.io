  <joint name="body_to_bucket" type="fixed">
    <parent link="body" />
    <child link="inner_bucket" />
    </joint>
  <joint name="lid_hinge" type="revolute">
    <origin xyz="0 0.151 0.345" rpy="0 0 0" />
    <parent link="body" />
    <child link="lid" />
    <axis xyz="-1 0 0" />
    <limit effort="6" velocity="2" lower="0" upper="1.35" />
    </joint>
  <joint name="pedal_pivot" type="revolute">
    <origin xyz="0 -0.158 0.055" rpy="0 0 0" />
    <parent link="body" />
    <child link="front_pedal" />
    <axis xyz="1 0 0" />
    <limit effort="8" velocity="2.5" lower="0" upper="0.45" />
    </joint>
  <joint name="handle_pivots" type="revolute">
    <origin xyz="0 0 0.318" rpy="0 0 0" />
    <parent link="inner_bucket" />
    <child link="bucket_handle" />
    <axis xyz="-1 0 0" />
    <limit effort="1.5" velocity="3" lower="0" upper="1.35" />
    </joint>
