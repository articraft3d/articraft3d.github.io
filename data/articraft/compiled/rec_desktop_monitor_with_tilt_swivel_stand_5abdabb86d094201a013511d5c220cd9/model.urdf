  <joint name="base_to_neck" type="continuous">
    <origin xyz="0 0 0.028" rpy="0 0 0" />
    <parent link="base" />
    <child link="neck" />
    <axis xyz="0 0 1" />
    <limit effort="5" velocity="2" />
    </joint>
