      <geometry>
        <mesh filename="assets/meshes/striker_wheel.obj" />
        </geometry>
      </collision>
    </link>
  <joint name="body_to_cap" type="revolute">
    <origin xyz="-0.0216 0 0.055" rpy="0 0 0" />
    <parent link="body" />
    <child link="cap" />
    <axis xyz="0 0 1" />
    <limit effort="2" velocity="4" lower="0" upper="2.05" />
    </joint>
  <joint name="body_to_chimney" type="fixed">
    <origin xyz="0 0 0.055" rpy="0 0 0" />
    <parent link="body" />
    <child link="chimney" />
    </joint>
  <joint name="chimney_to_striker_wheel" type="continuous">
    <origin xyz="0.0072 0 0.0165" rpy="0 0 0" />
    <parent link="chimney" />
    <child link="striker_wheel" />
    <axis xyz="0 1 0" />
    <limit effort="0.15" velocity="24" />
    </joint>
  </robot>
