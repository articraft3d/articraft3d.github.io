  <link name="chimney">
    <visual name="chimney_insert">
      <geometry>
        <mesh filename="assets/meshes/perforated_chimney.obj" />
        </geometry>
      <material name="brushed_steel">
        <color rgba="0.58 0.6 0.58 1" />
        </material>
