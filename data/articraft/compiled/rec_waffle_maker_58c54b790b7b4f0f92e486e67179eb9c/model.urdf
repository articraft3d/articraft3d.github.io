<robot name="square_clamshell_waffle_maker">
  <material name="warm_dark_enamel">
    <color rgba="0.1 0.105 0.095 1" />
    </material>
  <material name="matte_cast_iron">
    <color rgba="0.025 0.027 0.026 1" />
    </material>
  <material name="black_bakelite">
    <color rgba="0.006 0.006 0.005 1" />
    </material>
  <material name="brushed_steel">
    <color rgba="0.62 0.6 0.55 1" />
    </material>
  <material name="dial_mark_white">
    <color rgba="0.92 0.9 0.82 1" />
    </material>
  <link name="lower">
    <visual name="lower_shell">
      <origin xyz="0 0 0.052" rpy="0 0 0" />
      <geometry>
        <mesh filename="assets/meshes/lower_shell.obj" />
        </geometry>
      <material name="warm_dark_enamel">
        <color rgba="0.1 0.105 0.095 1" />
        </material>
      </visual>
    <visual name="lower_plate">
      <origin xyz="0 0 0.103" rpy="0 0 0" />
      <geometry>
        <mesh filename="assets/meshes/lower_plate.obj" />
        </geometry>
      <material name="matte_cast_iron">
        <color rgba="0.025 0.027 0.026 1" />
        </material>
      </visual>
    <visual name="rear_hinge_block">
      <origin xyz="-0.207 0 0.125" rpy="0 0 0" />
      <geometry>
        <box size="0.052 0.14 0.068" />
        </geometry>
      <material name="warm_dark_enamel">
        <color rgba="0.1 0.105 0.095 1" />
        </material>
      </visual>
    <visual name="hinge_pin">
      <origin xyz="-0.195 0 0.165" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.008" length="0.35" />
        </geometry>
      <material name="brushed_steel">
        <color rgba="0.62 0.6 0.55 1" />
        </material>
      </visual>
    <visual name="foot_0">
      <origin xyz="-0.13 -0.13 0.006" rpy="0 0 0" />
      <geometry>
        <box size="0.06 0.06 0.014" />
        </geometry>
      <material name="black_bakelite">
        <color rgba="0.006 0.006 0.005 1" />
        </material>
      </visual>
    <visual name="foot_1">
      <origin xyz="-0.13 0.13 0.006" rpy="0 0 0" />
      <geometry>
        <box size="0.06 0.06 0.014" />
        </geometry>
      <material name="black_bakelite">
        <color rgba="0.006 0.006 0.005 1" />
        </material>
      </visual>
    <visual name="foot_2">
      <origin xyz="0.13 -0.13 0.006" rpy="0 0 0" />
      <geometry>
        <box size="0.06 0.06 0.014" />
        </geometry>
      <material name="black_bakelite">
        <color rgba="0.006 0.006 0.005 1" />
        </material>
      </visual>
    <visual name="foot_3">
      <origin xyz="0.13 0.13 0.006" rpy="0 0 0" />
      <geometry>
        <box size="0.06 0.06 0.014" />
        </geometry>
      <material name="black_bakelite">
        <color rgba="0.006 0.006 0.005 1" />
        </material>
      </visual>
    </link>
  <link name="top">
    <visual name="top_cover">
      <origin xyz="0.205 0 0.034" rpy="0 0 0" />
      <geometry>
        <mesh filename="assets/meshes/top_cover.obj" />
        </geometry>
      <material name="warm_dark_enamel">
        <color rgba="0.1 0.105 0.095 1" />
        </material>
      </visual>
    <visual name="top_plate">
      <origin xyz="0.192 0 -0.014" rpy="0 0 0" />
      <geometry>
        <mesh filename="assets/meshes/top_plate.obj" />
        </geometry>
      <material name="matte_cast_iron">
        <color rgba="0.025 0.027 0.026 1" />
        </material>
      </visual>
    <visual name="front_handle">
      <geometry>
        <mesh filename="assets/meshes/front_handle.obj" />
        </geometry>
      <material name="black_bakelite">
        <color rgba="0.006 0.006 0.005 1" />
        </material>
      </visual>
    <visual name="hinge_straps">
      <geometry>
        <mesh filename="assets/meshes/hinge_straps.obj" />
        </geometry>
      <material name="brushed_steel">
        <color rgba="0.62 0.6 0.55 1" />
        </material>
      </visual>
    <visual name="hinge_barrel_0">
      <origin xyz="0 -0.112 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.015" length="0.062" />
        </geometry>
      <material name="brushed_steel">
        <color rgba="0.62 0.6 0.55 1" />
        </material>
      </visual>
    <visual name="hinge_barrel_1">
      <origin xyz="0 0.112 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.015" length="0.062" />
        </geometry>
      <material name="brushed_steel">
        <color rgba="0.62 0.6 0.55 1" />
        </material>
      </visual>
    </link>
  <link name="dial">
    <visual name="temperature_dial">
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <mesh filename="assets/meshes/temperature_dial.obj" />
        </geometry>
      <material name="black_bakelite">
        <color rgba="0.006 0.006 0.005 1" />
        </material>
      </visual>
    <visual name="dial_pointer">
      <origin xyz="0 -0.0215 0.011" rpy="0 0 0" />
      <geometry>
        <box size="0.005 0.003 0.022" />
        </geometry>
      <material name="dial_mark_white">
        <color rgba="0.92 0.9 0.82 1" />
        </material>
      </visual>
    </link>
  <joint name="lower_to_top" type="revolute">
    <origin xyz="-0.195 0 0.165" rpy="0 0 0" />
    <parent link="lower" />
    <child link="top" />
    <axis xyz="0 -1 0" />
    <limit effort="12" velocity="1.4" lower="0" upper="1.25" />
    </joint>
  <joint name="lower_to_dial" type="revolute">
    <origin xyz="0.09 -0.195 0.062" rpy="0 0 0" />
    <parent link="lower" />
    <child link="dial" />
    <axis xyz="0 -1 0" />
    <limit effort="0.4" velocity="3" lower="-2.35" upper="2.35" />
    </joint>
  </robot>
