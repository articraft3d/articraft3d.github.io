  <joint name="steering_axis" type="continuous">
    <parent link="head_tube" />
    <child link="steerer" />
    <axis xyz="0 0 1" />
    <limit effort="5" velocity="3.5" />
    </joint>
  <joint name="steerer_to_fork" type="fixed">
    <parent link="steerer" />
    <child link="fork" />
    </joint>
  <joint name="steerer_to_stem" type="fixed">
    <parent link="steerer" />
    <child link="stem" />
    </joint>
  <joint name="stem_to_handlebar" type="fixed">
    <parent link="stem" />
    <child link="handlebar" />
    </joint>
  <joint name="stem_to_faceplate" type="fixed">
    <parent link="stem" />
    <child link="faceplate" />
    </joint>
