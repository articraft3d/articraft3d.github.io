    <parent link="desktop" />
    <child link="handset" />
    </joint>
  <joint name="handset_to_up_paddle" type="revolute">
    <origin xyz="-0.037 -0.0435 0.004" rpy="0 0 0" />
    <parent link="handset" />
    <child link="up_paddle" />
    <axis xyz="-1 0 0" />
    <limit effort="0.4" velocity="3" lower="0" upper="0.35" />
    </joint>
  <joint name="handset_to_down_paddle" type="revolute">
    <origin xyz="0.037 -0.0435 0.004" rpy="0 0 0" />
    <parent link="handset" />
    <child link="down_paddle" />
    <axis xyz="-1 0 0" />
    <limit effort="0.4" velocity="3" lower="0" upper="0.35" />
    </joint>
  </robot>
