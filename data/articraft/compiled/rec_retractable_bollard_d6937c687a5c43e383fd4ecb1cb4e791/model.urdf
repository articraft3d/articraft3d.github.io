  <joint name="sleeve_to_post" type="prismatic">
    <origin xyz="0 0 0.045" rpy="0 0 0" />
    <parent link="sleeve" />
    <child link="post" />
    <axis xyz="0 0 1" />
    <limit effort="1200" velocity="0.35" lower="-0.5" upper="0" />
    </joint>
  <joint name="sleeve_to_flap" type="revolute">
    <origin xyz="-0.29 0 0.066" rpy="0 0 0" />
