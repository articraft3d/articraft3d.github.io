  <joint name="bracket_to_housing" type="fixed">
    <parent link="wall_bracket" />
    <child link="housing" />
    </joint>
  <joint name="housing_to_drum" type="continuous">
    <origin xyz="0 -0.045 0" rpy="0 0 0" />
