  <joint name="stand_to_post" type="prismatic">
    <origin xyz="0 0 0.77" rpy="0 0 0" />
    <parent link="stand" />
    <child link="post" />
    <axis xyz="0 0 1" />
    <limit effort="120" velocity="0.22" lower="0" upper="0.35" />
    </joint>
  <joint name="post_to_yoke" type="continuous">
    <origin xyz="0 0 0.7" rpy="0 0 0" />
    <parent link="post" />
    <child link="yoke" />
    <axis xyz="0 0 1" />
    <limit effort="25" velocity="1.2" />
    </joint>
  <joint name="yoke_to_can" type="revolute">
    <origin xyz="0 0 0.28" rpy="0 0 0" />
    <parent link="yoke" />
    <child link="can" />
    <axis xyz="0 -1 0" />
    <limit effort="35" velocity="1" lower="-0.75" upper="0.75" />
    </joint>
  <joint name="can_to_top_clip" type="revolute">
    <origin xyz="0.245 0 0.176" rpy="0 0 0" />
    <parent link="can" />
    <child link="top_clip" />
    <axis xyz="0 -1 0" />
