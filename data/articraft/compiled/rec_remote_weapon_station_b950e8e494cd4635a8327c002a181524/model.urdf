  <joint name="yaw" type="continuous">
    <origin xyz="0 0 0.29" rpy="0 0 0" />
    <parent link="yaw_base" />
    <child link="turret" />
    <axis xyz="0 0 1" />
    <limit effort="120" velocity="1" />
    </joint>
  <joint name="pitch" type="revolute">
    <origin xyz="0.54 0 0.28" rpy="0 0 0" />
    <parent link="turret" />
    <child link="cradle" />
    <axis xyz="0 -1 0" />
    <limit effort="85" velocity="1.2" lower="-0.35" upper="0.55" />
    </joint>
  <joint name="guard_hinge" type="revolute">
