  <joint name="base_to_jug" type="revolute">
    <origin xyz="0 0 0.223" rpy="0 0 0" />
    <parent link="base" />
    <child link="jug" />
    <axis xyz="0 0 1" />
    <limit effort="12" velocity="1.5" lower="0" upper="0.55" />
    </joint>
  <joint name="jug_to_blade" type="continuous">
    <origin xyz="0 0 0.066" rpy="0 0 0" />
    <parent link="jug" />
    <child link="blade" />
    <axis xyz="0 0 1" />
    <limit effort="0.8" velocity="90" />
    </joint>
  <joint name="jug_to_connector_cap" type="prismatic">
    <origin xyz="0 0 0.7" rpy="0 0 0" />
    <parent link="jug" />
    <child link="connector_cap" />
    <axis xyz="0 0 -1" />
    <limit effort="20" velocity="0.08" lower="0" upper="0.012" />
    </joint>
  <joint name="base_to_dial" type="revolute">
    <origin xyz="0 -0.19 0.09" rpy="1.5708 0 0" />
    <parent link="base" />
    <child link="dial" />
    <axis xyz="0 0 1" />
    <limit effort="0.4" velocity="5" lower="-2.4" upper="2.4" />
    </joint>
  </robot>
