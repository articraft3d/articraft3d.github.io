  <joint name="body_to_drum" type="continuous">
    <origin xyz="0.04 0 0.49" rpy="0 0 0" />
    <parent link="body" />
    <child link="drum" />
    <axis xyz="1 0 0" />
    <limit effort="80" velocity="25" />
    <dynamics damping="0.08" friction="0.02" />
    </joint>
