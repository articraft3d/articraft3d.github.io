    <origin xyz="0.39 0.335 0.49" rpy="0 0 0" />
    <parent link="body" />
    <child link="door" />
    <axis xyz="0 0 1" />
    <limit effort="120" velocity="1.2" lower="0" upper="1.95" />
    <dynamics damping="0.35" friction="0.08" />
    </joint>
