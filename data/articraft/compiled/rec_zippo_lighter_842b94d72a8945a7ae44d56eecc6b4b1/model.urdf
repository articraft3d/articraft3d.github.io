  <joint name="case_to_insert" type="prismatic">
    <parent link="case" />
    <child link="insert" />
    <axis xyz="0 0 1" />
    <limit effort="18" velocity="0.12" lower="0" upper="0.034" />
    </joint>
  <joint name="case_to_lid" type="revolute">
    <origin xyz="-0.0214 0 0.039" rpy="0 0 0" />
    <parent link="case" />
    <child link="lid" />
    <axis xyz="0 -1 0" />
    <limit effort="2" velocity="5" lower="0" upper="1.95" />
    </joint>
  <joint name="insert_to_wheel" type="continuous">
    <origin xyz="-0.006 0 0.0498" rpy="0 0 0" />
    <parent link="insert" />
    <child link="striker_wheel" />
    <axis xyz="0 1 0" />
    <limit effort="0.2" velocity="30" />
    </joint>
