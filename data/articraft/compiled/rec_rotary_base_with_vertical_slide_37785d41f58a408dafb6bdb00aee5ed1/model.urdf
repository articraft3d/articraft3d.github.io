  <joint name="pedestal_to_turntable" type="continuous">
    <origin xyz="0 0 0.225" rpy="0 0 0" />
    <parent link="pedestal" />
    <child link="turntable" />
    <axis xyz="0 0 1" />
    <limit effort="80" velocity="1.2" />
    </joint>
  <joint name="turntable_to_frame" type="fixed">
    <origin xyz="0 0 0.075" rpy="0 0 0" />
    <parent link="turntable" />
    <child link="elevator_frame" />
    </joint>
  <joint name="elevator_slide" type="prismatic">
    <origin xyz="0 0 0.255" rpy="0 0 0" />
    <parent link="elevator_frame" />
    <child link="carriage" />
    <axis xyz="0 0 1" />
    <limit effort="180" velocity="0.35" lower="0" upper="0.31" />
    </joint>
  </robot>
