  <joint name="base_to_cup" type="fixed">
    <parent link="motor_base" />
    <child link="cup_jar" />
    </joint>
  <joint name="cup_to_blade" type="continuous">
    <origin xyz="0 0 0.125" rpy="0 0 0" />
    <parent link="cup_jar" />
    <child link="blade_cross" />
    <axis xyz="0 0 1" />
    <limit effort="2" velocity="80" />
    </joint>
  <joint name="cup_to_flip_lid" type="revolute">
    <origin xyz="0.084 0 0.297" rpy="0 0 0" />
    <parent link="cup_jar" />
    <child link="flip_lid" />
    <axis xyz="0 1 0" />
    <limit effort="1" velocity="3" lower="0" upper="1.7" />
    </joint>
  </robot>
