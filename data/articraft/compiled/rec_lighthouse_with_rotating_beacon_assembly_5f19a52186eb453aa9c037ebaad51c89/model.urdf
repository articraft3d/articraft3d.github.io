<robot name="squat_pier_lighthouse">
  <link name="tower">
    <visual name="stone_body">
      <geometry>
        <mesh filename="assets/meshes/pier_stone_body.obj" />
        </geometry>
      <material name="warm_gray_stone">
        <color rgba="0.58 0.56 0.5 1" />
        </material>
      </visual>
    <visual name="stone_course_0">
      <origin xyz="0 0 0.28" rpy="0 0 0" />
      <geometry>
        <cylinder radius="1.34" length="0.025" />
        </geometry>
      <material name="dark_stone_courses">
        <color rgba="0.3 0.31 0.31 1" />
        </material>
      </visual>
    <visual name="stone_course_1">
      <origin xyz="0 0 0.44" rpy="0 0 0" />
      <geometry>
        <cylinder radius="1.34" length="0.025" />
        </geometry>
      <material name="dark_stone_courses">
        <color rgba="0.3 0.31 0.31 1" />
        </material>
      </visual>
    <visual name="stone_course_2">
      <origin xyz="0 0 1.02" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.72" length="0.025" />
        </geometry>
      <material name="dark_stone_courses">
        <color rgba="0.3 0.31 0.31 1" />
        </material>
      </visual>
    <visual name="stone_course_3">
      <origin xyz="0 0 1.55" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.67" length="0.025" />
        </geometry>
      <material name="dark_stone_courses">
        <color rgba="0.3 0.31 0.31 1" />
        </material>
      </visual>
    <visual name="stone_course_4">
      <origin xyz="0 0 2.08" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.62" length="0.025" />
        </geometry>
      <material name="dark_stone_courses">
        <color rgba="0.3 0.31 0.31 1" />
        </material>
      </visual>
    <visual name="wraparound_gallery">
      <geometry>
        <mesh filename="assets/meshes/wraparound_gallery.obj" />
        </geometry>
      <material name="weathered_green_metal">
        <color rgba="0.13 0.34 0.31 1" />
        </material>
      </visual>
    <visual name="lantern_frame">
      <geometry>
        <mesh filename="assets/meshes/lantern_frame_roof.obj" />
        </geometry>
      <material name="weathered_green_metal">
        <color rgba="0.13 0.34 0.31 1" />
        </material>
      </visual>
    <visual name="lantern_glass">
      <geometry>
        <mesh filename="assets/meshes/cylindrical_lantern_glass.obj" />
        </geometry>
      <material name="slightly_green_glass">
        <color rgba="0.58 0.86 0.92 0.35" />
        </material>
      </visual>
    <visual name="central_spindle">
      <origin xyz="0 0 3.14" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.025" length="1.12" />
        </geometry>
      <material name="blackened_metal">
        <color rgba="0.02 0.025 0.025 1" />
        </material>
      </visual>
    <visual name="door_hinge_pin">
      <geometry>
        <mesh filename="assets/meshes/fixed_door_hinge_pin.obj" />
        </geometry>
      <material name="blackened_metal">
        <color rgba="0.02 0.025 0.025 1" />
        </material>
      </visual>
    <collision name="stone_body">
      <geometry>
        <mesh filename="assets/meshes/pier_stone_body.obj" />
        </geometry>
      </collision>
    <collision name="stone_course_0">
      <origin xyz="0 0 0.28" rpy="0 0 0" />
      <geometry>
        <cylinder radius="1.34" length="0.025" />
        </geometry>
      </collision>
    <collision name="stone_course_1">
      <origin xyz="0 0 0.44" rpy="0 0 0" />
      <geometry>
        <cylinder radius="1.34" length="0.025" />
        </geometry>
      </collision>
    <collision name="stone_course_2">
      <origin xyz="0 0 1.02" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.72" length="0.025" />
        </geometry>
      </collision>
    <collision name="stone_course_3">
      <origin xyz="0 0 1.55" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.67" length="0.025" />
        </geometry>
      </collision>
    <collision name="stone_course_4">
      <origin xyz="0 0 2.08" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.62" length="0.025" />
        </geometry>
      </collision>
    <collision name="wraparound_gallery">
      <geometry>
        <mesh filename="assets/meshes/wraparound_gallery.obj" />
        </geometry>
      </collision>
    <collision name="lantern_frame">
      <geometry>
        <mesh filename="assets/meshes/lantern_frame_roof.obj" />
        </geometry>
      </collision>
    <collision name="lantern_glass">
      <geometry>
        <mesh filename="assets/meshes/cylindrical_lantern_glass.obj" />
        </geometry>
      </collision>
    <collision name="central_spindle">
      <origin xyz="0 0 3.14" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.025" length="1.12" />
        </geometry>
      </collision>
    <collision name="door_hinge_pin">
      <geometry>
        <mesh filename="assets/meshes/fixed_door_hinge_pin.obj" />
        </geometry>
      </collision>
    </link>
  <link name="beacon">
    <visual name="beacon_shell">
      <geometry>
        <mesh filename="assets/meshes/rotating_beacon_drum.obj" />
        </geometry>
      <material name="aged_brass">
        <color rgba="0.85 0.62 0.24 1" />
        </material>
      </visual>
    <visual name="front_lens">
      <origin xyz="0.185 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.042 0.2 0.16" />
        </geometry>
      <material name="warm_beacon_lens">
        <color rgba="1 0.8 0.23 0.9" />
        </material>
      </visual>
    <visual name="rear_lens">
      <origin xyz="-0.185 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.042 0.2 0.16" />
        </geometry>
      <material name="warm_beacon_lens">
        <color rgba="1 0.8 0.23 0.9" />
        </material>
      </visual>
    <collision name="beacon_shell">
      <geometry>
        <mesh filename="assets/meshes/rotating_beacon_drum.obj" />
        </geometry>
      </collision>
    <collision name="front_lens">
      <origin xyz="0.185 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.042 0.2 0.16" />
        </geometry>
      </collision>
    <collision name="rear_lens">
      <origin xyz="-0.185 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.042 0.2 0.16" />
        </geometry>
      </collision>
    </link>
  <link name="maintenance_door">
    <visual name="door_panel">
      <geometry>
        <mesh filename="assets/meshes/curved_maintenance_door.obj" />
        </geometry>
      <material name="faded_red_door">
        <color rgba="0.55 0.08 0.055 1" />
        </material>
      </visual>
    <collision name="door_panel">
      <geometry>
        <mesh filename="assets/meshes/curved_maintenance_door.obj" />
        </geometry>
      </collision>
    </link>
  <joint name="beacon_spin" type="continuous">
    <origin xyz="0 0 3.13" rpy="0 0 0" />
    <parent link="tower" />
    <child link="beacon" />
    <axis xyz="0 0 1" />
    <limit effort="8" velocity="2.5" />
    </joint>
  <joint name="door_hinge" type="revolute">
    <origin xyz="-0.159039 -0.436957 2.78" rpy="0 0 0" />
    <parent link="tower" />
    <child link="maintenance_door" />
    <axis xyz="0 0 -1" />
    <limit effort="18" velocity="1.5" lower="0" upper="1.35" />
    </joint>
  </robot>
