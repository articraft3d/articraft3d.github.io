  <joint name="frame_to_wheel" type="continuous">
    <origin xyz="0 0 1.15" rpy="0 0 0" />
    <parent link="timber_frame" />
    <child link="wheel" />
    <axis xyz="1 0 0" />
    <limit effort="120" velocity="1.5" />
    </joint>
  <joint name="frame_to_service_hatch" type="revolute">
    <origin xyz="0.7 -0.32 1" rpy="0 0 0" />
    <parent link="timber_frame" />
    <child link="service_hatch" />
    <axis xyz="0 0 -1" />
    <limit effort="4" velocity="2" lower="0" upper="1.65" />
    </joint>
  </robot>
