  <joint name="sleeve_to_upper_post" type="prismatic">
    <origin xyz="0 0 0.82" rpy="0 0 0" />
    <parent link="sleeve" />
    <child link="upper_post" />
    <axis xyz="0 0 1" />
    <limit effort="180" velocity="0.25" lower="0" upper="0.35" />
    </joint>
  <joint name="post_to_service_cap" type="continuous">
    <origin xyz="0.126 0 0.63" rpy="0 0 0" />
