  <joint name="pedestal_to_body" type="fixed">
    <origin xyz="0 0 0.625" rpy="0 0 0" />
    <parent link="pedestal" />
    <child link="mechanism_body" />
    </joint>
  <joint name="body_to_jar" type="fixed">
    <origin xyz="0 0 0.28" rpy="0 0 0" />
    <parent link="mechanism_body" />
    <child link="glass_jar" />
    </joint>
  <joint name="jar_to_lid" type="revolute">
    <origin xyz="0 0.198 0.46" rpy="0 0 0" />
    <parent link="glass_jar" />
    <child link="refill_lid" />
    <axis xyz="-1 0 0" />
    <limit effort="3" velocity="2" lower="0" upper="1.2" />
    </joint>
  <joint name="body_to_knob" type="continuous">
    <origin xyz="0 -0.198 0.145" rpy="0 0 0" />
    <parent link="mechanism_body" />
    <child link="dispense_knob" />
    <axis xyz="0 -1 0" />
    <limit effort="2" velocity="8" />
    </joint>
  <joint name="body_to_coin_cover" type="revolute">
    <origin xyz="0.153 -0.181 0.112" rpy="0 0 0" />
    <parent link="mechanism_body" />
    <child link="coin_return_cover" />
    <axis xyz="0 0 1" />
    <limit effort="1" velocity="2" lower="0" upper="1.1" />
    </joint>
  </robot>
