    <collision name="filament_bridge">
      <origin xyz="0 0 0.079" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.00062" length="0.0096" />
        </geometry>
      </collision>
    </link>
  <joint name="socket_to_bulb" type="continuous">
    <parent link="socket" />
    <child link="bulb" />
    <axis xyz="0 0 1" />
    <limit effort="0.4" velocity="8" />
    </joint>
  </robot>
