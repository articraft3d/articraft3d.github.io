      <geometry>
        <cylinder radius="0.00038" length="0.027" />
        </geometry>
      <material name="warm_filament">
        <color rgba="1 0.64 0.2 1" />
        </material>
      </visual>
    <visual name="filament_bridge">
      <origin xyz="0 0 0.079" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.00062" length="0.0096" />
        </geometry>
      <material name="warm_filament">
        <color rgba="1 0.64 0.2 1" />
        </material>
      </visual>
    <collision name="threaded_base">
      <geometry>
        <mesh filename="assets/meshes/threaded_base.obj" />
        </geometry>
      </collision>
    <collision name="base_seating_flange">
      <origin xyz="0 0 0.04525" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0152" length="0.0025" />
