    <collision name="glass_envelope">
      <geometry>
        <mesh filename="assets/meshes/glass_envelope.obj" />
        </geometry>
      </collision>
    <collision name="base_insulator">
      <origin xyz="0 0 0.0074" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0076" length="0.0042" />
        </geometry>
      </collision>
    <collision name="base_contact">
      <origin xyz="0 0 0.0048" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0046" length="0.0024" />
        </geometry>
      </collision>
    <collision name="filament_support_0">
      <origin xyz="-0.0048 0 0.0655" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.00038" length="0.027" />
        </geometry>
      </collision>
    <collision name="filament_support_1">
