  <joint name="mount_to_table" type="revolute">
    <parent link="mount" />
    <child link="table" />
    <axis xyz="0 1 0" />
    <limit effort="180" velocity="0.55" lower="-0.785398" upper="0.785398" />
    <dynamics damping="2.5" friction="3" />
    </joint>
  <joint name="table_to_tilt_lock" type="continuous">
    <origin xyz="0 0.285 0" rpy="0 0 0" />
