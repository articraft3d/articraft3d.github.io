  <joint name="base_to_lower" type="prismatic">
    <origin xyz="0 0 0.67" rpy="0 0 0" />
    <parent link="ballast_base" />
    <child link="lower_pole" />
    <axis xyz="0 0 1" />
    <limit effort="120" velocity="0.25" lower="0" upper="0.35" />
    </joint>
  <joint name="lower_to_upper" type="prismatic">
    <origin xyz="0 0 1.05" rpy="0 0 0" />
