  <joint name="casing_to_rotor" type="continuous">
    <parent link="casing" />
    <child link="rotor" />
    <axis xyz="1 0 0" />
    <limit effort="20000" velocity="900" />
    <dynamics damping="0.02" friction="0.002" />
    </joint>
  </robot>
