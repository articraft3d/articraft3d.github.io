    <origin xyz="0 0 0.548" rpy="0 0 0" />
    <parent link="seat_tube" />
    <child link="post_body" />
    <axis xyz="0 0 1" />
    <limit effort="120" velocity="0.35" lower="0" upper="0.18" />
    </joint>
  <joint name="post_to_clamp" type="fixed">
    <origin xyz="0 0 0.36" rpy="0 0 0" />
    <parent link="post_body" />
    <child link="saddle_clamp" />
    </joint>
  <joint name="clamp_to_saddle" type="fixed">
    <parent link="saddle_clamp" />
    <child link="saddle" />
    </joint>
  </robot>
