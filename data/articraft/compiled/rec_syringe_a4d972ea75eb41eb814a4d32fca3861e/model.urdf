    <child link="plunger" />
    <axis xyz="-1 0 0" />
    <limit effort="35" velocity="0.12" lower="0" upper="0.055" />
    </joint>
  <joint name="adjuster_spin" type="revolute">
    <origin xyz="-0.045 0 0" rpy="0 0 0" />
    <parent link="plunger" />
    <child link="fine_adjuster" />
    <axis xyz="1 0 0" />
    <limit effort="1" velocity="2" lower="-3.14159" upper="3.14159" />
    </joint>
  </robot>
