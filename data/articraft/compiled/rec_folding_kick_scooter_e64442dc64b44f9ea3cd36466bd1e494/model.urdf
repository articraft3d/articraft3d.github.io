  <joint name="deck_hinge" type="revolute">
    <parent link="rear_deck" />
    <child link="front_deck" />
    <axis xyz="0 -1 0" />
    <limit effort="35" velocity="1.5" lower="0" upper="2.35" />
    </joint>
  <joint name="stem_hinge" type="revolute">
    <origin xyz="0.34 0 0.08" rpy="0 0 0" />
    <parent link="front_deck" />
    <child link="stem" />
    <axis xyz="0 -1 0" />
    <limit effort="18" velocity="1.8" lower="0" upper="1.55" />
    </joint>
  <joint name="rear_brake_hinge" type="revolute">
    <origin xyz="-0.405 0 0.03" rpy="0 0 0" />
    <parent link="rear_deck" />
    <child link="fender_brake" />
    <axis xyz="0 1 0" />
    <limit effort="9" velocity="2.5" lower="-0.35" upper="0.9" />
    </joint>
  <joint name="rear_wheel_spin" type="continuous">
    <origin xyz="-0.455 0 -0.066" rpy="0 0 0" />
    <parent link="rear_deck" />
    <child link="rear_wheel" />
    <axis xyz="0 1 0" />
    <limit effort="4" velocity="20" />
    </joint>
  <joint name="front_wheel_spin" type="continuous">
    <origin xyz="0.44 0 -0.066" rpy="0 0 0" />
    <parent link="front_deck" />
    <child link="front_wheel" />
    <axis xyz="0 1 0" />
    <limit effort="4" velocity="20" />
    </joint>
  </robot>
