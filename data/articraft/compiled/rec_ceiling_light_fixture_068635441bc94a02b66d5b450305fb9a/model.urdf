  <joint name="canopy_to_lock_button" type="prismatic">
    <origin xyz="0.158 0 -0.02" rpy="0 0 0" />
    <parent link="canopy" />
    <child link="lock_button" />
    <axis xyz="-1 0 0" />
    <limit effort="8" velocity="0.05" lower="0" upper="0.012" />
    <dynamics damping="0.2" friction="0.8" />
    </joint>
  <joint name="canopy_to_cord" type="prismatic">
