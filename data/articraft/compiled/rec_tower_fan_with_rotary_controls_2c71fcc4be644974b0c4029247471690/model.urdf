  <joint name="base_to_body" type="revolute">
    <origin xyz="0 0 0.056" rpy="0 0 0" />
    <parent link="base" />
    <child link="body" />
    <axis xyz="0 0 1" />
    <limit effort="12" velocity="1.2" lower="-1.05" upper="1.05" />
    </joint>
  <joint name="body_to_blower" type="continuous">
    <origin xyz="0 0 0.42" rpy="0 0 0" />
