  <joint name="shoulder_yaw" type="revolute">
    <origin xyz="0 0 0.31" rpy="0 0 0" />
    <parent link="pedestal" />
    <child link="upper_arm" />
    <axis xyz="0 0 1" />
    <limit effort="120" velocity="1.8" lower="-3.14159" upper="3.14159" />
    </joint>
  <joint name="elbow" type="revolute">
    <origin xyz="0.62 0 0.095" rpy="0 0 0" />
