  <joint name="housing_to_pendulum" type="revolute">
    <origin xyz="0 0.082 0.105" rpy="0 0 0" />
    <parent link="housing" />
    <child link="pendulum" />
    <axis xyz="0 1 0" />
    <limit effort="0.3" velocity="4" lower="-0.12" upper="0.12" />
    </joint>
  <joint name="pendulum_to_weight" type="prismatic">
    <origin xyz="0 0.045 0.155" rpy="0 0 0" />
    <parent link="pendulum" />
    <child link="pendulum_weight" />
    <axis xyz="0 0 1" />
    <limit effort="1" velocity="0.25" lower="0" upper="0.105" />
    </joint>
  <joint name="housing_to_crown" type="continuous">
    <origin xyz="0 0 0.322" rpy="0 0 0" />
    <parent link="housing" />
    <child link="crown_knob" />
    <axis xyz="0 0 1" />
    <limit effort="0.4" velocity="8" />
    </joint>
  </robot>
