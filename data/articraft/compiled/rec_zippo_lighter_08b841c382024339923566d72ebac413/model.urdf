    <limit effort="2" velocity="4" lower="0" upper="2.05" />
    </joint>
  <joint name="chimney_to_striker_wheel" type="continuous">
    <origin xyz="-0.008 0 0.047" rpy="0 0 0" />
    <parent link="chimney" />
    <child link="striker_wheel" />
    <axis xyz="0 1 0" />
    <limit effort="0.05" velocity="25" />
    </joint>
  <joint name="lid_to_cam_lever" type="revolute">
    <origin xyz="0.0062 0 0.007" rpy="0 0 0" />
    <parent link="lid" />
    <child link="cam_lever" />
    <axis xyz="0 1 0" />
    <limit effort="0.1" velocity="6" lower="-0.4" upper="0.2" />
    <mimic joint="case_to_lid" multiplier="-0.22" />
    </joint>
  </robot>
