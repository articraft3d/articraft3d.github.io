  <joint name="wall_to_wall_arm" type="revolute">
    <origin xyz="0.02 0 0" rpy="0 0 0" />
    <parent link="wall_plate" />
    <child link="wall_arm" />
    <axis xyz="0 0 1" />
    <limit effort="60" velocity="1.2" lower="-1.35" upper="1.35" />
    </joint>
  <joint name="wall_arm_to_head_arm" type="revolute">
    <origin xyz="0.46 0 0" rpy="0 0 0" />
    <parent link="wall_arm" />
    <child link="head_arm" />
    <axis xyz="0 0 1" />
    <limit effort="55" velocity="1.2" lower="-2.45" upper="2.45" />
    </joint>
  <joint name="head_arm_to_swivel" type="revolute">
    <origin xyz="0.42 0 0" rpy="0 0 0" />
    <parent link="head_arm" />
    <child link="swivel_support" />
    <axis xyz="0 0 1" />
    <limit effort="35" velocity="1.3" lower="-1.4" upper="1.4" />
    </joint>
  <joint name="swivel_to_tilt" type="revolute">
    <origin xyz="0.15 0 0" rpy="0 0 0" />
    <parent link="swivel_support" />
    <child link="tilt_support" />
    <axis xyz="0 1 0" />
    <limit effort="25" velocity="0.8" lower="-0.35" upper="0.35" />
    </joint>
  <joint name="tilt_to_frame" type="fixed">
    <parent link="tilt_support" />
    <child link="head_frame" />
    </joint>
  </robot>
