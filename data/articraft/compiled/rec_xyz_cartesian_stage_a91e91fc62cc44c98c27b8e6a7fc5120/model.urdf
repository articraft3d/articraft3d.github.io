    </link>
  <joint name="base_to_lower" type="prismatic">
    <origin xyz="-0.22 0 0.093" rpy="0 0 0" />
    <parent link="base" />
    <child link="lower_carriage" />
    <axis xyz="1 0 0" />
    <limit effort="350" velocity="0.45" lower="0" upper="0.44" />
    <dynamics damping="8" friction="1.2" />
    </joint>
  <joint name="lower_to_cross" type="prismatic">
    <origin xyz="0 -0.1 0.106" rpy="0 0 0" />
    <parent link="lower_carriage" />
    <child link="cross_slide" />
    <axis xyz="0 1 0" />
    <limit effort="220" velocity="0.35" lower="0" upper="0.2" />
    <dynamics damping="6" friction="0.8" />
    </joint>
  <joint name="cross_to_vertical" type="prismatic">
    <origin xyz="0 0 0.075" rpy="0 0 0" />
    <parent link="cross_slide" />
    <child link="vertical_slide" />
    <axis xyz="0 0 1" />
    <limit effort="180" velocity="0.22" lower="0" upper="0.16" />
    <dynamics damping="5" friction="0.6" />
    </joint>
  </robot>
