  <joint name="base_to_tilt_frame" type="revolute">
    <origin xyz="0 0 0.58" rpy="0 0 0" />
    <parent link="base" />
    <child link="tilt_frame" />
    <axis xyz="1 0 0" />
    <limit effort="500" velocity="0.6" lower="-1.05" upper="1.05" />
    <dynamics damping="12" friction="4" />
    </joint>
  <joint name="tilt_frame_to_turntable" type="continuous">
    <origin xyz="0 0 0.08" rpy="0 0 0" />
    <parent link="tilt_frame" />
    <child link="turntable" />
    <axis xyz="0 0 1" />
    <limit effort="260" velocity="1.2" />
    <dynamics damping="4" friction="2" />
    </joint>
