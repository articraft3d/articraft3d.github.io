  <joint name="base_to_meridian" type="revolute">
    <origin xyz="0 0 0.34" rpy="0.410152 0 0" />
    <parent link="base" />
    <child link="meridian" />
    <axis xyz="1 0 0" />
    <limit effort="4" velocity="1.5" lower="-0.65" upper="0.65" />
    </joint>
  <joint name="meridian_to_globe" type="continuous">
