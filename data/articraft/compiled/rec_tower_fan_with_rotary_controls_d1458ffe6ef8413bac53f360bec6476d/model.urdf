  <joint name="base_to_body" type="revolute">
    <origin xyz="0 0 0.071" rpy="0 0 0" />
    <parent link="base" />
    <child link="body_shell" />
    <axis xyz="0 0 1" />
    <limit effort="8" velocity="1.2" lower="-0.8" upper="0.8" />
    </joint>
  <joint name="body_to_deck" type="fixed">
    <origin xyz="0 0 0.835" rpy="0 0 0" />
    <parent link="body_shell" />
    <child link="control_deck" />
    </joint>
  <joint name="body_to_blower" type="continuous">
    <origin xyz="0 -0.006 0.43" rpy="0 0 0" />
    <parent link="body_shell" />
    <child link="blower_wheel" />
    <axis xyz="0 0 1" />
    <limit effort="3" velocity="45" />
    </joint>
  <joint name="deck_to_timer" type="continuous">
    <origin xyz="-0.043 0.01 0.025" rpy="0 0 0" />
    <parent link="control_deck" />
    <child link="timer_dial" />
    <axis xyz="0 0 1" />
    <limit effort="0.2" velocity="6" />
    </joint>
  <joint name="deck_to_speed" type="continuous">
    <origin xyz="0.02 0.01 0.025" rpy="0 0 0" />
    <parent link="control_deck" />
    <child link="speed_dial" />
    <axis xyz="0 0 1" />
    <limit effort="0.2" velocity="6" />
    </joint>
  <joint name="deck_to_button" type="prismatic">
    <origin xyz="0.057 -0.027 0.025" rpy="0 0 0" />
    <parent link="control_deck" />
    <child link="osc_button" />
    <axis xyz="0 0 -1" />
    <limit effort="2" velocity="0.1" lower="0" upper="0.008" />
    </joint>
  </robot>
