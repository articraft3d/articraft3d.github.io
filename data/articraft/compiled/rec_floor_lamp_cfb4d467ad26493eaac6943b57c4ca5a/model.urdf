    <child link="upper_pole" />
    <axis xyz="0 0 1" />
    <limit effort="80" velocity="0.18" lower="0" upper="0.35" />
    </joint>
  <joint name="shade_tilt" type="revolute">
    <origin xyz="0.32 0 0.7" rpy="0 0 0" />
