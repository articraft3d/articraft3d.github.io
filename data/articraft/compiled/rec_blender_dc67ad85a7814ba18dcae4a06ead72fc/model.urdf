  <joint name="handle_to_shaft" type="revolute">
    <parent link="motor_handle" />
    <child link="shaft" />
    <axis xyz="0 0 1" />
    <limit effort="8" velocity="1.2" lower="-0.45" upper="0.45" />
    </joint>
  <joint name="shaft_to_blade_rotor" type="continuous">
    <origin xyz="0 0 -0.337" rpy="0 0 0" />
    <parent link="shaft" />
    <child link="blade_rotor" />
    <axis xyz="0 0 1" />
    <limit effort="0.25" velocity="80" />
    </joint>
  <joint name="handle_to_power_trigger" type="revolute">
    <origin xyz="0 -0.046 0.225" rpy="0 0 0" />
    <parent link="motor_handle" />
    <child link="power_trigger" />
    <axis xyz="1 0 0" />
    <limit effort="2" velocity="3" lower="0" upper="0.35" />
    </joint>
