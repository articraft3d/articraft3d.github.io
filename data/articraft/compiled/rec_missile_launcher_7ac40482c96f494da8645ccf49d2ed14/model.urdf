  <joint name="pedestal_to_yaw_head" type="revolute">
    <origin xyz="0 0 0.41" rpy="0 0 0" />
    <parent link="pedestal" />
    <child link="yaw_head" />
    <axis xyz="0 0 1" />
    <limit effort="45" velocity="1.2" lower="-3.14159" upper="3.14159" />
    </joint>
  <joint name="yaw_head_to_tube_pair" type="revolute">
    <origin xyz="0 0 0.32" rpy="0 0 0" />
    <parent link="yaw_head" />
    <child link="tube_pair" />
    <axis xyz="0 -1 0" />
    <limit effort="32" velocity="0.9" lower="-0.15" upper="0.85" />
    </joint>
  <joint name="yaw_head_to_handwheel" type="continuous">
    <origin xyz="-0.125 -0.266 0.245" rpy="0 0 0" />
    <parent link="yaw_head" />
    <child link="handwheel" />
    <axis xyz="0 1 0" />
    <limit effort="2" velocity="5" />
    </joint>
