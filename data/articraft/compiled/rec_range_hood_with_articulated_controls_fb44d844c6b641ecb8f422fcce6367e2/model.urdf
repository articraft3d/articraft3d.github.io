  <joint name="hood_to_button" type="prismatic">
    <origin xyz="0 -0.32 0.075" rpy="0 0 0" />
    <parent link="hood" />
    <child link="button" />
    <axis xyz="0 1 0" />
    <limit effort="3" velocity="0.08" lower="0" upper="0.006" />
    </joint>
  </robot>
