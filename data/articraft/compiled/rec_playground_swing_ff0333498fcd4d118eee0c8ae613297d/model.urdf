  <joint name="beam_to_swivel" type="continuous">
    <parent link="beam" />
    <child link="swivel_block" />
    <axis xyz="0 0 1" />
    <limit effort="50" velocity="1.5" />
    </joint>
  <joint name="swivel_to_hanger" type="revolute">
    <origin xyz="0 0 -0.1" rpy="0 0 0" />
    <parent link="swivel_block" />
    <child link="seat_hanger" />
    <axis xyz="1 0 0" />
    <limit effort="80" velocity="2.5" lower="-0.75" upper="0.75" />
    </joint>
  </robot>
