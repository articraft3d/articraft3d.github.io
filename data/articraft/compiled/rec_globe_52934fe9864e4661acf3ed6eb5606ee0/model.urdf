  <joint name="stand_to_meridian" type="revolute">
    <origin xyz="0 0 0.34" rpy="0.410152 0 0" />
    <parent link="stand" />
    <child link="meridian" />
    <axis xyz="1 0 0" />
    <limit effort="4" velocity="1.2" lower="-0.523599" upper="0.523599" />
    </joint>
  <joint name="meridian_to_globe" type="continuous">
