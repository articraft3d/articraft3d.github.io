  <joint name="deck_to_slide_base" type="revolute">
    <origin xyz="0 0 0.04" rpy="0 0 0" />
    <parent link="deck" />
    <child link="slide_base" />
    <axis xyz="0 0 1" />
    <limit effort="400" velocity="0.35" lower="-0.55" upper="0.55" />
    </joint>
  <joint name="slide_base_to_carriage" type="prismatic">
