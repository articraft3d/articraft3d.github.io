  <joint name="stand_to_yoke" type="fixed">
    <parent link="stand" />
    <child link="yoke" />
    </joint>
  <joint name="tilt_axis" type="revolute">
    <origin xyz="0 0 1.25" rpy="0 0 0" />
    <parent link="yoke" />
    <child link="spotlight_can" />
    <axis xyz="0 -1 0" />
    <limit effort="75" velocity="0.8" lower="-0.65" upper="0.85" />
    <dynamics damping="0.25" friction="4" />
    </joint>
