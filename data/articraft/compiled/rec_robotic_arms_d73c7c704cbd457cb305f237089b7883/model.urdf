  <joint name="base_to_shoulder" type="revolute">
    <origin xyz="0 0 0.34" rpy="0 0 0" />
    <parent link="base" />
    <child link="shoulder" />
    <axis xyz="0 0 1" />
    <limit effort="900" velocity="1.4" lower="-3.14" upper="3.14" />
    <dynamics damping="2" friction="0.2" />
    </joint>
