  <joint name="column_slide" type="prismatic">
    <origin xyz="0 0 1.55" rpy="0 0 0" />
    <parent link="lower_stand" />
    <child link="center_column" />
    <axis xyz="0 0 1" />
    <limit effort="160" velocity="0.18" lower="0" upper="0.45" />
    </joint>
  <joint name="yoke_pan" type="continuous">
    <origin xyz="0 0 0.802" rpy="0 0 0" />
