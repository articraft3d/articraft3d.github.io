<robot name="smart_home_puck_remote">
  <material name="warm_matte_white">
    <color rgba="0.86 0.84 0.79 1" />
    </material>
  <material name="graphite_selector">
    <color rgba="0.03 0.035 0.04 1" />
    </material>
  <material name="soft_touch_gray">
    <color rgba="0.18 0.19 0.2 1" />
    </material>
  <material name="underside_battery_door">
    <color rgba="0.62 0.61 0.57 1" />
    </material>
  <material name="tiny_status_led">
    <color rgba="0.25 0.95 0.72 1" />
    </material>
  <link name="body">
    <visual name="rounded_shell">
      <geometry>
        <mesh filename="assets/meshes/rounded_puck_body.obj" />
        </geometry>
      <material name="warm_matte_white">
        <color rgba="0.86 0.84 0.79 1" />
        </material>
      </visual>
    <visual name="center_touch_disc">
      <origin xyz="0 0 0.0115" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0205" length="0.0012" />
        </geometry>
      <material name="soft_touch_gray">
        <color rgba="0.18 0.19 0.2 1" />
        </material>
      </visual>
    <visual name="status_led">
      <origin xyz="0 0.012 0.01225" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0021" length="0.00045" />
        </geometry>
      <material name="tiny_status_led">
        <color rgba="0.25 0.95 0.72 1" />
        </material>
      </visual>
    <collision name="rounded_shell">
      <geometry>
        <mesh filename="assets/meshes/rounded_puck_body.obj" />
        </geometry>
      </collision>
    <collision name="center_touch_disc">
      <origin xyz="0 0 0.0115" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0205" length="0.0012" />
        </geometry>
      </collision>
    <collision name="status_led">
      <origin xyz="0 0.012 0.01225" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0021" length="0.00045" />
        </geometry>
      </collision>
    </link>
  <link name="selector_ring">
    <visual name="selector_ring">
      <geometry>
        <mesh filename="assets/meshes/selector_ring_with_ticks.obj" />
        </geometry>
      <material name="graphite_selector">
        <color rgba="0.03 0.035 0.04 1" />
        </material>
      </visual>
    <collision name="selector_ring">
      <geometry>
        <mesh filename="assets/meshes/selector_ring_with_ticks.obj" />
        </geometry>
      </collision>
    </link>
  <link name="battery_door">
    <visual name="door_panel">
      <geometry>
        <mesh filename="assets/meshes/sliding_battery_door.obj" />
        </geometry>
      <material name="underside_battery_door">
        <color rgba="0.62 0.61 0.57 1" />
        </material>
      </visual>
    <collision name="door_panel">
      <geometry>
        <mesh filename="assets/meshes/sliding_battery_door.obj" />
        </geometry>
      </collision>
    </link>
  <joint name="body_to_selector_ring" type="continuous">
    <origin xyz="0 0 0.011" rpy="0 0 0" />
    <parent link="body" />
    <child link="selector_ring" />
    <axis xyz="0 0 1" />
    <limit effort="0.25" velocity="8" />
    </joint>
  <joint name="body_to_battery_door" type="prismatic">
    <origin xyz="0 0 -0.011" rpy="0 0 0" />
    <parent link="body" />
    <child link="battery_door" />
    <axis xyz="1 0 0" />
    <limit effort="8" velocity="0.18" lower="0" upper="0.03" />
    </joint>
  </robot>
