    <collision name="speed_knob">
      <geometry>
        <mesh filename="assets/meshes/speed_dial.obj" />
        </geometry>
      </collision>
    <collision name="speed_pointer">
      <origin xyz="0 0.01 0.025" rpy="0 0 0" />
      <geometry>
        <box size="0.004 0.03 0.002" />
        </geometry>
      </collision>
    </link>
  <link name="timer_dial">
    <visual name="timer_knob">
      <geometry>
        <mesh filename="assets/meshes/timer_dial.obj" />
        </geometry>
      <material name="satin_black_plastic">
        <color rgba="0.025 0.026 0.028 1" />
        </material>
      </visual>
    <visual name="timer_pointer">
      <origin xyz="0 0.009 0.024" rpy="0 0 0" />
      <geometry>
        <box size="0.004 0.027 0.002" />
        </geometry>
      <material name="white_control_marks">
        <color rgba="0.95 0.94 0.88 1" />
