<robot name="tower_fan">
  <material name="warm_white_plastic">
    <color rgba="0.88 0.86 0.8 1" />
    </material>
  <material name="satin_black_plastic">
    <color rgba="0.025 0.026 0.028 1" />
    </material>
  <material name="weighted_dark_base">
    <color rgba="0.11 0.115 0.12 1" />
    </material>
  <material name="shadow_grille_grey">
    <color rgba="0.18 0.19 0.2 1" />
    </material>
  <material name="white_control_marks">
    <color rgba="0.95 0.94 0.88 1" />
    </material>
  <material name="soft_grey_button">
    <color rgba="0.55 0.57 0.58 1" />
    </material>
  <link name="base">
    <visual name="weighted_base">
      <geometry>
        <mesh filename="assets/meshes/weighted_base.obj" />
        </geometry>
      <material name="weighted_dark_base">
        <color rgba="0.11 0.115 0.12 1" />
        </material>
      </visual>
    <collision name="weighted_base">
      <geometry>
        <mesh filename="assets/meshes/weighted_base.obj" />
        </geometry>
      </collision>
    </link>
