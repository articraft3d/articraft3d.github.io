    <collision name="lower_bearing_arm">
      <origin xyz="0 0 0.145" rpy="0 0 0" />
      <geometry>
        <box size="0.196 0.014 0.012" />
        </geometry>
      </collision>
    <collision name="upper_bearing_arm">
      <origin xyz="0 0 0.955" rpy="0 0 0" />
      <geometry>
        <box size="0.196 0.014 0.012" />
        </geometry>
      </collision>
    <collision name="lower_bearing">
      <origin xyz="0 0 0.145" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.021" length="0.01" />
        </geometry>
      </collision>
    <collision name="upper_bearing">
      <origin xyz="0 0 0.955" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.021" length="0.01" />
        </geometry>
      </collision>
    </link>
  <link name="blower_wheel">
    <visual name="squirrel_cage">
      <geometry>
        <mesh filename="assets/meshes/blower_wheel.obj" />
        </geometry>
      <material name="satin_black_plastic">
        <color rgba="0.025 0.026 0.028 1" />
        </material>
      </visual>
    <visual name="center_core">
      <geometry>
        <cylinder radius="0.026" length="0.798" />
        </geometry>
      <material name="satin_black_plastic">
        <color rgba="0.025 0.026 0.028 1" />
        </material>
      </visual>
    <collision name="squirrel_cage">
      <geometry>
        <mesh filename="assets/meshes/blower_wheel.obj" />
        </geometry>
      </collision>
    <collision name="center_core">
      <geometry>
        <cylinder radius="0.026" length="0.798" />
        </geometry>
      </collision>
    </link>
  <link name="speed_dial">
    <visual name="speed_knob">
      <geometry>
        <mesh filename="assets/meshes/speed_dial.obj" />
        </geometry>
      <material name="satin_black_plastic">
        <color rgba="0.025 0.026 0.028 1" />
        </material>
      </visual>
    <visual name="speed_pointer">
      <origin xyz="0 0.01 0.025" rpy="0 0 0" />
