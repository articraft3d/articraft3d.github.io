      <geometry>
        <box size="0.004 0.027 0.002" />
        </geometry>
      </collision>
    </link>
  <link name="oscillation_button">
    <visual name="button_cap">
      <origin xyz="0 0 0.0055" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.017" length="0.011" />
        </geometry>
      <material name="soft_grey_button">
        <color rgba="0.55 0.57 0.58 1" />
        </material>
      </visual>
    <collision name="button_cap">
      <origin xyz="0 0 0.0055" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.017" length="0.011" />
        </geometry>
      </collision>
    </link>
  <joint name="base_to_body" type="revolute">
    <origin xyz="0 0 0.075" rpy="0 0 0" />
    <parent link="base" />
    <child link="body" />
    <axis xyz="0 0 1" />
    <limit effort="30" velocity="0.8" lower="-0.85" upper="0.85" />
    </joint>
  <joint name="body_to_blower_wheel" type="continuous">
    <origin xyz="0 -0.006 0.55" rpy="0 0 0" />
    <parent link="body" />
    <child link="blower_wheel" />
    <axis xyz="0 0 1" />
    <limit effort="1.5" velocity="60" />
    </joint>
  <joint name="body_to_speed_dial" type="continuous">
    <origin xyz="-0.06 -0.02 1.114" rpy="0 0 0" />
    <parent link="body" />
    <child link="speed_dial" />
    <axis xyz="0 0 1" />
    <limit effort="0.4" velocity="6" />
    </joint>
  <joint name="body_to_timer_dial" type="continuous">
    <origin xyz="0.025 -0.02 1.114" rpy="0 0 0" />
    <parent link="body" />
    <child link="timer_dial" />
    <axis xyz="0 0 1" />
    <limit effort="0.4" velocity="6" />
    </joint>
  <joint name="body_to_oscillation_button" type="prismatic">
    <origin xyz="0.088 -0.02 1.117" rpy="0 0 0" />
    <parent link="body" />
    <child link="oscillation_button" />
    <axis xyz="0 0 -1" />
    <limit effort="4" velocity="0.06" lower="0" upper="0.01" />
    </joint>
  </robot>
