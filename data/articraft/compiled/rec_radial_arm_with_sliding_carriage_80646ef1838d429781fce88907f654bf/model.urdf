  <link name="arm">
    <visual name="hub_sleeve">
      <geometry>
        <mesh filename="assets/meshes/arm_hub_sleeve.obj" />
        </geometry>
      <material name="warm_yellow" />
      </visual>
    <visual name="tapered_beam">
      <geometry>
        <mesh filename="assets/meshes/tapered_boom_arm.obj" />
        </geometry>
      <material name="warm_yellow" />
      </visual>
    <visual name="slide_rail">
      <origin xyz="0.85 0 -0.075" rpy="0 0 0" />
      <geometry>
        <box size="1.25 0.07 0.035" />
