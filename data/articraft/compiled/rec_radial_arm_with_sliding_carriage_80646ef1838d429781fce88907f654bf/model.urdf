      </collision>
    </link>
  <joint name="post_to_arm" type="revolute">
    <origin xyz="0 0 1.6" rpy="0 0 0" />
    <parent link="post" />
    <child link="arm" />
    <axis xyz="0 0 1" />
    <limit effort="180" velocity="0.8" lower="-3.14159" upper="3.14159" />
    </joint>
  <joint name="arm_to_carriage" type="prismatic">
    <origin xyz="0.45 0 -0.075" rpy="0 0 0" />
    <parent link="arm" />
    <child link="carriage" />
    <axis xyz="1 0 0" />
    <limit effort="120" velocity="0.35" lower="0" upper="0.7" />
    </joint>
  </robot>
