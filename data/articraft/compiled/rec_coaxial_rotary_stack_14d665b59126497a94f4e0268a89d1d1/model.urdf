  <joint name="shaft_to_turntable" type="revolute">
    <origin xyz="0 0 0.08" rpy="0 0 0" />
    <parent link="center_shaft" />
    <child link="base_turntable" />
    <axis xyz="0 0 1" />
    <limit effort="8" velocity="2.5" lower="-3.14159" upper="3.14159" />
    </joint>
  <joint name="shaft_to_middle_ring" type="revolute">
    <origin xyz="0 0 0.155" rpy="0 0 0" />
