  <joint name="frame_to_plunger" type="prismatic">
    <origin xyz="0 0 0.8" rpy="0 0 0" />
    <parent link="frame" />
    <child link="plunger" />
    <axis xyz="0 0 1" />
    <limit effort="120" velocity="0.32" lower="0" upper="0.25" />
    </joint>
  <joint name="plunger_to_grip" type="continuous">
    <origin xyz="0 0 0.135" rpy="0 0 0" />
