    <child link="grip" />
    <axis xyz="1 0 0" />
    <limit effort="2" velocity="8" />
    </joint>
  <joint name="frame_to_needle" type="revolute">
    <origin xyz="0 -0.071 0.205" rpy="0 0 0" />
    <parent link="frame" />
    <child link="needle" />
    <axis xyz="0 -1 0" />
    <limit effort="0.2" velocity="10" lower="-2.25" upper="2.25" />
    </joint>
