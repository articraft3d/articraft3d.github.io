  <joint name="base_to_rotary" type="revolute">
    <origin xyz="0 0 0.185" rpy="0 0 0" />
    <parent link="base_frame" />
    <child link="rotary_stage" />
    <axis xyz="0 -1 0" />
    <limit effort="220" velocity="1.2" lower="-0.35" upper="0.75" />
