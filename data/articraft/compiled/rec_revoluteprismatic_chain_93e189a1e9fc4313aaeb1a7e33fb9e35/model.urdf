    </joint>
  <joint name="rotary_to_carriage" type="prismatic">
    <origin xyz="0.28 0 0" rpy="0 0 0" />
    <parent link="rotary_stage" />
    <child link="output_carriage" />
    <axis xyz="1 0 0" />
    <limit effort="450" velocity="0.35" lower="0" upper="0.22" />
    <dynamics damping="1.2" friction="0.15" />
    </joint>
