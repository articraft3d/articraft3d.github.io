  <joint name="pedestal_to_turret" type="revolute">
    <origin xyz="0 0 0.3" rpy="0 0 0" />
    <parent link="pedestal" />
    <child link="turret_base" />
    <axis xyz="0 0 1" />
    <limit effort="180" velocity="1.3" lower="-3.14159" upper="3.14159" />
    </joint>
  <joint name="turret_to_cradle" type="revolute">
    <origin xyz="0 0 0.44" rpy="0 0 0" />
    <parent link="turret_base" />
    <child link="weapon_cradle" />
    <axis xyz="0 -1 0" />
    <limit effort="90" velocity="0.9" lower="-0.35" upper="0.85" />
    </joint>
  </robot>
