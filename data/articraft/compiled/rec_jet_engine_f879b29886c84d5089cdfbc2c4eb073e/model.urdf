  <joint name="stand_to_nacelle" type="fixed">
    <parent link="stand" />
    <child link="nacelle" />
    </joint>
  <joint name="nacelle_to_fan" type="continuous">
    <origin xyz="-0.57 0 0" rpy="0 0 0" />
    <parent link="nacelle" />
    <child link="fan_rotor" />
    <axis xyz="1 0 0" />
    <limit effort="45" velocity="120" />
    </joint>
  <joint name="nacelle_to_sleeve" type="prismatic">
    <parent link="nacelle" />
    <child link="reverser_sleeve" />
    <axis xyz="1 0 0" />
    <limit effort="250" velocity="0.18" lower="0" upper="0.3" />
    </joint>
  </robot>
