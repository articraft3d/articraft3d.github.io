  <joint name="side_plate_to_body" type="revolute">
    <parent link="side_plate" />
    <child link="hinged_body" />
    <axis xyz="0 0 1" />
    <limit effort="30" velocity="1.2" lower="-0.15" upper="1.65" />
    </joint>
  <joint name="body_to_slide" type="prismatic">
