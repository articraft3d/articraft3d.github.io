    <axis xyz="1 0 0" />
    <limit effort="80" velocity="0.35" lower="0" upper="0.18" />
    </joint>
  <joint name="slide_to_tip_fork" type="revolute">
    <origin xyz="0.39 0 0.024" rpy="0 0 0" />
