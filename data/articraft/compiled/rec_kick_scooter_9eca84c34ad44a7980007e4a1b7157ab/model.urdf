  <joint name="deck_to_stem" type="revolute">
    <origin xyz="0.372 0 0.2" rpy="0 0 0" />
    <parent link="deck" />
    <child link="stem" />
    <axis xyz="0 -1 0" />
    <limit effort="35" velocity="1.5" lower="0" upper="1.45" />
    </joint>
  <joint name="stem_to_front_fork" type="revolute">
    <origin xyz="0.07 0 -0.02" rpy="0 0 0" />
    <parent link="stem" />
    <child link="front_fork" />
    <axis xyz="0 0 1" />
    <limit effort="8" velocity="3" lower="-0.7" upper="0.7" />
    </joint>
  <joint name="front_fork_to_front_wheel" type="continuous">
    <origin xyz="0.075 0 -0.118" rpy="0 0 0" />
