  <joint name="base_to_middle" type="prismatic">
    <origin xyz="0 0 0.95" rpy="0 0 0" />
    <parent link="ballast_base" />
    <child link="middle_stage" />
    <axis xyz="0 0 1" />
    <limit effort="120" velocity="0.18" lower="0" upper="0.55" />
    </joint>
  <joint name="middle_to_upper" type="prismatic">
    <origin xyz="0 0 0.75" rpy="0 0 0" />
    <parent link="middle_stage" />
    <child link="upper_stage" />
    <axis xyz="0 0 1" />
    <limit effort="80" velocity="0.16" lower="0" upper="0.45" />
    </joint>
  <joint name="upper_to_pan" type="revolute">
    <origin xyz="0 0 0.535" rpy="0 0 0" />
    <parent link="upper_stage" />
    <child link="pan_yoke" />
    <axis xyz="0 0 1" />
    <limit effort="18" velocity="1.2" lower="-3.14159" upper="3.14159" />
    </joint>
  <joint name="pan_to_camera" type="revolute">
    <origin xyz="0 0 0.2" rpy="0 0 0" />
    <parent link="pan_yoke" />
    <child link="camera_head" />
    <axis xyz="0 1 0" />
    <limit effort="8" velocity="1" lower="-0.45" upper="0.8" />
    </joint>
