    <child link="lower_drum" />
    <axis xyz="0 0 1" />
    <limit effort="40" velocity="1.5" lower="-3.14159" upper="3.14159" />
    </joint>
  <joint name="lower_drum_to_bridge" type="fixed">
    <origin xyz="0 0 0.3" rpy="0 0 0" />
