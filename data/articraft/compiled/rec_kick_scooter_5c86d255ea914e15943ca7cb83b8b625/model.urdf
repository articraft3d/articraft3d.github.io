  <joint name="steering_yaw" type="revolute">
    <origin xyz="0.315 0 0.052" rpy="0 0 0" />
    <parent link="deck_frame" />
    <child link="bar_fork" />
    <axis xyz="0 0 1" />
    <limit effort="25" velocity="4" lower="-1.65" upper="1.65" />
    </joint>
  <joint name="front_wheel_spin" type="continuous">
    <parent link="bar_fork" />
    <child link="front_wheel" />
    <axis xyz="0 1 0" />
    <limit effort="2" velocity="80" />
    </joint>
  <joint name="rear_wheel_spin" type="continuous">
    <origin xyz="-0.255 0 0.052" rpy="0 0 0" />
    <parent link="deck_frame" />
    <child link="rear_wheel" />
    <axis xyz="0 1 0" />
