  <joint name="mast_slide" type="prismatic">
    <origin xyz="0.18 0 0.55" rpy="0 0 0" />
    <parent link="mast" />
    <child link="carriage" />
    <axis xyz="0 0 1" />
    <limit effort="180" velocity="0.25" lower="0" upper="0.5" />
    </joint>
  <joint name="root_pivot" type="revolute">
    <parent link="carriage" />
    <child link="upper_link" />
    <axis xyz="0 0 1" />
    <limit effort="65" velocity="1.2" lower="-0.95" upper="0.95" />
    </joint>
  <joint name="elbow_pivot" type="revolute">
    <origin xyz="0.36 0 0" rpy="0 0 0" />
    <parent link="upper_link" />
    <child link="forearm" />
    <axis xyz="0 0 1" />
    <limit effort="45" velocity="1.4" lower="-1.2" upper="1.2" />
    </joint>
