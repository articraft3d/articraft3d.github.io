<robot name="screw_cap_bottle">
  <material name="translucent_pet">
    <color rgba="0.55 0.82 1 0.42" />
    </material>
  <material name="clear_neck_detail">
    <color rgba="0.72 0.92 1 0.58" />
    </material>
  <material name="matte_white_cap">
    <color rgba="0.94 0.94 0.9 1" />
    </material>
  <link name="bottle">
    <visual name="body_sections">
      <geometry>
        <mesh filename="assets/meshes/bottle_shell.obj" />
        </geometry>
      <material name="translucent_pet">
        <color rgba="0.55 0.82 1 0.42" />
        </material>
      </visual>
    <visual name="neck_support_ring">
      <origin xyz="0 0 0.2015" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.029" length="0.007" />
        </geometry>
      <material name="clear_neck_detail">
        <color rgba="0.72 0.92 1 0.58" />
        </material>
      </visual>
    <visual name="neck_thread">
      <geometry>
        <mesh filename="assets/meshes/neck_thread.obj" />
        </geometry>
      <material name="clear_neck_detail">
        <color rgba="0.72 0.92 1 0.58" />
        </material>
      </visual>
    <collision name="body_sections">
      <geometry>
        <mesh filename="assets/meshes/bottle_shell.obj" />
        </geometry>
      </collision>
    <collision name="neck_support_ring">
      <origin xyz="0 0 0.2015" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.029" length="0.007" />
        </geometry>
      </collision>
    <collision name="neck_thread">
      <geometry>
        <mesh filename="assets/meshes/neck_thread.obj" />
        </geometry>
      </collision>
    </link>
  <link name="cap">
    <visual name="cap_shell">
      <geometry>
        <mesh filename="assets/meshes/ribbed_cap_shell.obj" />
        </geometry>
      <material name="matte_white_cap">
        <color rgba="0.94 0.94 0.9 1" />
        </material>
      </visual>
    <collision name="cap_shell">
      <geometry>
        <mesh filename="assets/meshes/ribbed_cap_shell.obj" />
        </geometry>
      </collision>
    </link>
  <joint name="neck_to_cap" type="continuous">
    <origin xyz="0 0 0.205" rpy="0 0 0" />
    <parent link="bottle" />
    <child link="cap" />
    <axis xyz="0 0 1" />
    <limit effort="1.5" velocity="8" />
    <dynamics damping="0.02" friction="0.04" />
    </joint>
  </robot>
