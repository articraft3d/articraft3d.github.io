    </link>
  <link name="lower_stage">
    <visual name="lower_platter">
      <geometry>
        <mesh filename="assets/meshes/lower_stage.obj" />
        </geometry>
      <material name="dark_anodized_plate">
        <color rgba="0.05 0.055 0.06 1" />
        </material>
      </visual>
    <collision name="lower_platter">
      <geometry>
        <mesh filename="assets/meshes/lower_stage.obj" />
        </geometry>
      </collision>
    </link>
  <link name="middle_ring">
