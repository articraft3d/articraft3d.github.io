  <joint name="sleeve_to_post" type="prismatic">
    <origin xyz="0 0 0.02" rpy="0 0 0" />
    <parent link="sleeve" />
    <child link="post" />
    <axis xyz="0 0 1" />
    <limit effort="800" velocity="0.2" lower="0" upper="0.25" />
    </joint>
  <joint name="sleeve_to_lock_cover" type="revolute">
    <origin xyz="0.247 0 0.047" rpy="0 0 0" />
    <parent link="sleeve" />
    <child link="lock_cover" />
    <axis xyz="0 -1 0" />
    <limit effort="4" velocity="2.5" lower="0" upper="1.65" />
    </joint>
  <joint name="post_to_top_cap" type="continuous">
    <origin xyz="0 0 0.65" rpy="0 0 0" />
    <parent link="post" />
    <child link="top_cap" />
    <axis xyz="0 0 1" />
    <limit effort="1.5" velocity="5" />
    </joint>
