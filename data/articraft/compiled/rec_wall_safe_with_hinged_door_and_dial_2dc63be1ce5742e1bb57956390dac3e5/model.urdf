  <joint name="door_hinge" type="revolute">
    <origin xyz="0.205 -0.05 0" rpy="0 0 0" />
    <parent link="body" />
    <child link="door" />
    <axis xyz="0 0 1" />
    <limit effort="35" velocity="1.2" lower="0" upper="1.75" />
    </joint>
  <joint name="dial_spin" type="continuous">
    <origin xyz="-0.213 -0.032 0.05" rpy="0 0 0" />
    <parent link="door" />
    <child link="dial" />
    <axis xyz="0 -1 0" />
    <limit effort="0.4" velocity="8" />
    </joint>
  <joint name="handle_turn" type="revolute">
    <origin xyz="-0.213 -0.032 -0.055" rpy="0 0 0" />
    <parent link="door" />
    <child link="handle" />
    <axis xyz="0 -1 0" />
    <limit effort="6" velocity="4" lower="0" upper="1.5708" />
    </joint>
  <joint name="tray_slide" type="prismatic">
