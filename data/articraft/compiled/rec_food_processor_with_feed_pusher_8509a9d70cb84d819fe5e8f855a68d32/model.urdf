  <joint name="base_to_bowl" type="fixed">
    <origin xyz="0 0 0.385" rpy="0 0 0" />
    <parent link="base" />
    <child link="bowl" />
    </joint>
  <joint name="bowl_to_lid" type="fixed">
    <origin xyz="0 0 0.34" rpy="0 0 0" />
    <parent link="bowl" />
    <child link="lid" />
    </joint>
  <joint name="lid_to_chimney" type="fixed">
    <origin xyz="0 0.03 0.022" rpy="0 0 0" />
    <parent link="lid" />
    <child link="chimney" />
    </joint>
  <joint name="chimney_to_pusher" type="prismatic">
    <origin xyz="0 0 0.22" rpy="0 0 0" />
    <parent link="chimney" />
    <child link="pusher" />
    <axis xyz="0 0 1" />
    <limit effort="18" velocity="0.35" lower="0" upper="0.12" />
    </joint>
  <joint name="base_to_spindle" type="continuous">
    <origin xyz="0 0 0.389" rpy="0 0 0" />
    <parent link="base" />
    <child link="spindle" />
    <axis xyz="0 0 1" />
    <limit effort="12" velocity="30" />
    </joint>
  <joint name="base_to_dial" type="continuous">
    <origin xyz="0 -0.1455 0.245" rpy="0 0 0" />
    <parent link="base" />
    <child link="dial" />
    <axis xyz="0 -1 0" />
    <limit effort="1.2" velocity="8" />
    </joint>
  <joint name="base_to_rocker_0" type="revolute">
    <origin xyz="-0.033 -0.1455 0.124" rpy="0 0 0" />
    <parent link="base" />
    <child link="rocker_0" />
    <axis xyz="1 0 0" />
    <limit effort="2" velocity="3" lower="-0.18" upper="0.18" />
    </joint>
  <joint name="base_to_rocker_1" type="revolute">
    <origin xyz="0.033 -0.1455 0.124" rpy="0 0 0" />
