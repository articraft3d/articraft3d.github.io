    <visual name="pivot_boss_0">
      <origin xyz="-0.098 0 0.021" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.006" length="0.01" />
        </geometry>
      <material name="satin_pivot_metal">
        <color rgba="0.7 0.72 0.72 1" />
        </material>
      </visual>
    <visual name="pivot_boss_1">
      <origin xyz="-0.098 0 -0.021" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.006" length="0.01" />
        </geometry>
      <material name="satin_pivot_metal">
        <color rgba="0.7 0.72 0.72 1" />
        </material>
      </visual>
    <collision name="body_shell">
      <geometry>
        <mesh filename="assets/meshes/rounded_speaker_body.obj" />
        </geometry>
      </collision>
    <collision name="end_cap_0">
      <origin xyz="-0.093 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="assets/meshes/rubber_end_cap_0.obj" />
        </geometry>
      </collision>
    <collision name="end_cap_1">
      <origin xyz="0.093 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="assets/meshes/rubber_end_cap_1.obj" />
        </geometry>
      </collision>
    <collision name="front_grille">
      <origin xyz="0.012 0.029 -0.002" rpy="-1.5708 0 0" />
      <geometry>
        <mesh filename="assets/meshes/front_perforated_grille.obj" />
        </geometry>
      </collision>
    <collision name="control_strip">
      <origin xyz="0.014 -0.006 0.0315" rpy="0 0 0" />
      <geometry>
        <box size="0.13 0.02 0.003" />
        </geometry>
      </collision>
    <collision name="switch_slot">
      <origin xyz="0.034 -0.006 0.0336" rpy="0 0 0" />
      <geometry>
        <box size="0.046 0.011 0.0012" />
