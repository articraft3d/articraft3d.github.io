      </collision>
    <collision name="power_mark_0">
      <origin xyz="0.009 -0.014 0.0333" rpy="0 0 0" />
      <geometry>
        <box size="0.004 0.0015 0.001" />
        </geometry>
      </collision>
    <collision name="power_mark_1">
      <origin xyz="0.058 -0.014 0.0333" rpy="0 0 0" />
      <geometry>
        <box size="0.007 0.0015 0.001" />
        </geometry>
      </collision>
    <collision name="pivot_boss_0">
      <origin xyz="-0.098 0 0.021" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.006" length="0.01" />
        </geometry>
      </collision>
    <collision name="pivot_boss_1">
      <origin xyz="-0.098 0 -0.021" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.006" length="0.01" />
        </geometry>
      </collision>
    </link>
  <link name="carry_loop">
    <visual name="loop_frame">
      <geometry>
        <mesh filename="assets/meshes/carry_loop_frame.obj" />
        </geometry>
      <material name="matte_black_rubber">
        <color rgba="0.015 0.016 0.017 1" />
        </material>
      </visual>
    <collision name="loop_frame">
      <geometry>
        <mesh filename="assets/meshes/carry_loop_frame.obj" />
        </geometry>
      </collision>
    </link>
  <link name="power_slider">
    <visual name="slider_cap">
      <origin xyz="0 0 0.002" rpy="0 0 0" />
      <geometry>
        <box size="0.016 0.008 0.004" />
        </geometry>
      <material name="blue_power_slider">
        <color rgba="0.02 0.35 0.85 1" />
        </material>
      </visual>
    <visual name="thumb_ridge">
      <origin xyz="0 0 0.005" rpy="0 0 0" />
      <geometry>
        <box size="0.01 0.003 0.002" />
        </geometry>
      <material name="charcoal_control_strip">
        <color rgba="0.05 0.055 0.06 1" />
        </material>
      </visual>
    <collision name="slider_cap">
      <origin xyz="0 0 0.002" rpy="0 0 0" />
      <geometry>
        <box size="0.016 0.008 0.004" />
        </geometry>
      </collision>
    <collision name="thumb_ridge">
      <origin xyz="0 0 0.005" rpy="0 0 0" />
      <geometry>
        <box size="0.01 0.003 0.002" />
        </geometry>
      </collision>
    </link>
  <joint name="body_to_carry_loop" type="revolute">
    <origin xyz="-0.102 0 0" rpy="0 0 0" />
    <parent link="body" />
    <child link="carry_loop" />
    <axis xyz="0 0 1" />
    <limit effort="1.2" velocity="3" lower="0" upper="1.35" />
    </joint>
  <joint name="body_to_power_slider" type="prismatic">
    <origin xyz="0.034 -0.006 0.0342" rpy="0 0 0" />
    <parent link="body" />
    <child link="power_slider" />
    <axis xyz="1 0 0" />
    <limit effort="0.8" velocity="0.15" lower="-0.01" upper="0.01" />
    </joint>
  </robot>
