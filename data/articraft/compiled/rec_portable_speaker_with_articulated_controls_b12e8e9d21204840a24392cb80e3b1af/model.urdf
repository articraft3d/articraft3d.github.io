      </visual>
    <visual name="control_strip">
      <origin xyz="0.014 -0.006 0.0315" rpy="0 0 0" />
      <geometry>
        <box size="0.13 0.02 0.003" />
        </geometry>
      <material name="charcoal_control_strip">
        <color rgba="0.05 0.055 0.06 1" />
        </material>
      </visual>
    <visual name="switch_slot">
      <origin xyz="0.034 -0.006 0.0336" rpy="0 0 0" />
      <geometry>
        <box size="0.046 0.011 0.0012" />
        </geometry>
      <material name="dark_perforated_grille">
        <color rgba="0.02 0.023 0.025 1" />
        </material>
      </visual>
    <visual name="power_mark_0">
