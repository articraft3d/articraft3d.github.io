<robot name="travel_speaker">
  <link name="body">
    <visual name="body_shell">
      <geometry>
        <mesh filename="assets/meshes/rounded_speaker_body.obj" />
        </geometry>
      <material name="warm_gray_anodized_body">
        <color rgba="0.42 0.44 0.45 1" />
        </material>
      </visual>
    <visual name="end_cap_0">
      <origin xyz="-0.093 0 0" rpy="0 0 0" />
      <geometry>
