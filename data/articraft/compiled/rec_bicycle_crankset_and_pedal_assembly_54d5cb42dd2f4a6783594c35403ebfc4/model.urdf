  <joint name="bottom_bracket_to_crank" type="continuous">
    <parent link="bottom_bracket" />
    <child link="crank" />
    <axis xyz="1 0 0" />
    <limit effort="80" velocity="18" />
    <dynamics damping="0.02" friction="0.01" />
    </joint>
  <joint name="crank_to_drive_pedal" type="continuous">
    <origin xyz="0.089 0 -0.17" rpy="0 0 0" />
    <parent link="crank" />
    <child link="drive_pedal" />
    <axis xyz="1 0 0" />
    <limit effort="12" velocity="20" />
    <dynamics damping="0.01" friction="0.003" />
    </joint>
  <joint name="crank_to_opposite_pedal" type="continuous">
