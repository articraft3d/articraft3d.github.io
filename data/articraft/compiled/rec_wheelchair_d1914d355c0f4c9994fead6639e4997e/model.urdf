  <joint name="left_rear_spin" type="continuous">
    <origin xyz="-0.18 0.37 0.31" rpy="0 0 1.5708" />
    <parent link="frame" />
    <child link="left_rear_wheel" />
    <axis xyz="1 0 0" />
    <limit effort="20" velocity="12" />
    <dynamics damping="0.02" friction="0.01" />
    </joint>
  <joint name="right_rear_spin" type="continuous">
    <origin xyz="-0.18 -0.37 0.31" rpy="0 0 -1.5708" />
