    </joint>
  <joint name="left_caster_swivel" type="continuous">
    <origin xyz="0.36 0.15 0.2" rpy="0 0 0" />
    <parent link="frame" />
    <child link="left_caster_fork" />
    <axis xyz="0 0 1" />
    <limit effort="8" velocity="8" />
    <dynamics damping="0.04" friction="0.02" />
    </joint>
