  <joint name="body_to_cap_turn" type="revolute">
    <origin xyz="0 0 0.242" rpy="0 0 0" />
    <parent link="body" />
    <child link="cap_axis" />
    <axis xyz="0 0 1" />
    <limit effort="2" velocity="6" lower="0" upper="6.28319" />
    </joint>
  <joint name="cap_thread_lift" type="prismatic">
    <parent link="cap_axis" />
    <child link="cap" />
    <axis xyz="0 0 1" />
    <limit effort="18" velocity="0.04" lower="0" upper="0.014" />
    </joint>
