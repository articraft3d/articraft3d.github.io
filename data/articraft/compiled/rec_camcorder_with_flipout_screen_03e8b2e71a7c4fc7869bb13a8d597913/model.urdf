  <joint name="barrel_to_focus_ring" type="continuous">
    <origin xyz="0.119 0 0.004" rpy="0 0 0" />
    <parent link="body" />
    <child link="focus_ring" />
    <axis xyz="1 0 0" />
    <limit effort="0.25" velocity="8" />
    </joint>
  <joint name="body_to_front_lens" type="fixed">
    <origin xyz="0.13 0 0.004" rpy="0 0 0" />
    <parent link="body" />
    <child link="front_lens" />
    </joint>
  <joint name="body_to_flip_screen" type="revolute">
    <origin xyz="0.058 0.045 0.003" rpy="0 0 0" />
    <parent link="body" />
    <child link="flip_screen" />
    <axis xyz="0 0 -1" />
    <limit effort="0.35" velocity="2" lower="0" upper="1.75" />
    </joint>
  <joint name="top_to_mode_dial" type="continuous">
    <origin xyz="-0.052 0 0.056" rpy="0 0 0" />
    <parent link="body" />
    <child link="mode_dial" />
    <axis xyz="0 0 1" />
    <limit effort="0.18" velocity="6" />
    </joint>
  </robot>
