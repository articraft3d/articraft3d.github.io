  <joint name="base_to_swivel" type="revolute">
    <origin xyz="0 0 0.032" rpy="0 0 0" />
    <parent link="base_plate" />
    <child link="swivel_stage" />
    <axis xyz="0 0 1" />
    <limit effort="80" velocity="1.2" lower="-3.14159" upper="3.14159" />
    </joint>
  <joint name="swivel_to_tilt" type="revolute">
    <origin xyz="0 0 0.125" rpy="0 0 0" />
    <parent link="swivel_stage" />
    <child link="tilt_stage" />
    <axis xyz="0 1 0" />
    <limit effort="100" velocity="0.8" lower="-0.65" upper="0.65" />
    </joint>
  <joint name="tilt_to_moving_jaw" type="prismatic">
    <origin xyz="0.045 0 0" rpy="0 0 0" />
    <parent link="tilt_stage" />
    <child link="moving_jaw" />
    <axis xyz="-1 0 0" />
    <limit effort="250" velocity="0.08" lower="0" upper="0.12" />
    </joint>
  <joint name="tilt_to_leadscrew" type="continuous">
    <origin xyz="0 0 0.078" rpy="0 0 0" />
    <parent link="tilt_stage" />
    <child link="leadscrew" />
    <axis xyz="1 0 0" />
    <limit effort="18" velocity="8" />
    </joint>
  </robot>
