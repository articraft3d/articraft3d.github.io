    <visual name="hinge_pin_1">
      <origin xyz="-0.137 0.158 0.462" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.015" length="0.04" />
        </geometry>
      <material name="dark_machined_metal">
        <color rgba="0.07 0.075 0.08 1" />
        </material>
