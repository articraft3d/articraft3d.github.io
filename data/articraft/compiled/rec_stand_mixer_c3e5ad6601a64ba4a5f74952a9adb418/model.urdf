      <geometry>
        <mesh filename="assets/meshes/bowl_shell.obj" />
        </geometry>
      <material name="brushed_stainless">
        <color rgba="0.78 0.78 0.74 1" />
        </material>
      </visual>
    </link>
  <link name="head">
    <visual name="head_shell">
      <geometry>
        <mesh filename="assets/meshes/head_shell.obj" />
        </geometry>
      <material name="brushed_red_enamel">
        <color rgba="0.58 0.06 0.035 1" />
        </material>
      </visual>
    <visual name="hinge_barrel">
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.043" length="0.245" />
        </geometry>
      <material name="brushed_red_enamel">
        <color rgba="0.58 0.06 0.035 1" />
        </material>
      </visual>
    <visual name="drive_plate">
      <origin xyz="0.32 0 -0.106" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.043" length="0.014" />
        </geometry>
      <material name="dark_machined_metal">
        <color rgba="0.07 0.075 0.08 1" />
        </material>
      </visual>
    </link>
  <link name="flat_beater">
    <visual name="beater_frame">
      <geometry>
        <mesh filename="assets/meshes/flat_beater.obj" />
        </geometry>
      <material name="brushed_stainless">
        <color rgba="0.78 0.78 0.74 1" />
        </material>
      </visual>
    </link>
  <link name="speed_knob">
    <visual name="knob_cap">
      <origin xyz="0 -0.015 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.034" length="0.03" />
        </geometry>
      <material name="black_plastic">
        <color rgba="0.015 0.015 0.014 1" />
        </material>
      </visual>
    <visual name="knob_grip">
      <origin xyz="0 -0.033 0" rpy="0 0 0" />
      <geometry>
        <box size="0.01 0.008 0.046" />
        </geometry>
      <material name="dark_machined_metal">
        <color rgba="0.07 0.075 0.08 1" />
        </material>
      </visual>
    </link>
  <link name="lock_slider">
    <visual name="slider_tab">
      <origin xyz="0 0.012 0" rpy="0 0 0" />
      <geometry>
        <box size="0.052 0.024 0.024" />
        </geometry>
      <material name="black_plastic">
        <color rgba="0.015 0.015 0.014 1" />
        </material>
      </visual>
    <visual name="slider_rib">
      <origin xyz="-0.018 0.026 0" rpy="0 0 0" />
      <geometry>
        <box size="0.018 0.014 0.032" />
        </geometry>
      <material name="dark_machined_metal">
        <color rgba="0.07 0.075 0.08 1" />
        </material>
      </visual>
    </link>
  <joint name="base_to_bowl_stage" type="prismatic">
    <origin xyz="0.18 0 0.09" rpy="0 0 0" />
    <parent link="base" />
    <child link="bowl_stage" />
    <axis xyz="1 0 0" />
    <limit effort="80" velocity="0.12" lower="-0.035" upper="0.055" />
    </joint>
  <joint name="stage_to_bowl" type="fixed">
    <origin xyz="0 0 0.024" rpy="0 0 0" />
    <parent link="bowl_stage" />
    <child link="bowl" />
    </joint>
  <joint name="base_to_head" type="revolute">
    <origin xyz="-0.137 0 0.462" rpy="0 0 0" />
    <parent link="base" />
    <child link="head" />
    <axis xyz="0 -1 0" />
    <limit effort="30" velocity="0.9" lower="0" upper="1.0821" />
    </joint>
  <joint name="head_to_flat_beater" type="continuous">
    <origin xyz="0.32 0 -0.113" rpy="0 0 0" />
    <parent link="head" />
    <child link="flat_beater" />
    <axis xyz="0 0 1" />
    <limit effort="8" velocity="32" />
    </joint>
  <joint name="base_to_speed_knob" type="revolute">
    <origin xyz="-0.072 -0.125 0.275" rpy="0 0 0" />
    <parent link="base" />
    <child link="speed_knob" />
    <axis xyz="0 -1 0" />
    <limit effort="1.2" velocity="3" lower="0" upper="4.97419" />
    </joint>
  <joint name="base_to_lock_slider" type="prismatic">
    <origin xyz="0.1 0.183 0.065" rpy="0 0 0" />
    <parent link="base" />
    <child link="lock_slider" />
    <axis xyz="1 0 0" />
    <limit effort="3" velocity="0.08" lower="-0.018" upper="0.018" />
    </joint>
  </robot>
