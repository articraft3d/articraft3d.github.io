        </geometry>
      <material name="black_plastic">
        <color rgba="0.015 0.015 0.014 1" />
        </material>
      </visual>
    </link>
  <link name="bowl_stage">
    <visual name="stage_plate">
      <geometry>
        <mesh filename="assets/meshes/bowl_stage.obj" />
        </geometry>
      <material name="dark_machined_metal">
        <color rgba="0.07 0.075 0.08 1" />
        </material>
      </visual>
    </link>
  <link name="bowl">
