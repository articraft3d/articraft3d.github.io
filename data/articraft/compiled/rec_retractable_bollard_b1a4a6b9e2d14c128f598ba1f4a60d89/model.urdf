  <joint name="sleeve_to_post" type="prismatic">
    <parent link="sleeve" />
    <child link="post" />
    <axis xyz="0 0 1" />
    <limit effort="2500" velocity="0.25" lower="0" upper="0.45" />
    </joint>
  <joint name="post_to_cap" type="continuous">
    <origin xyz="0 0 0.65" rpy="0 0 0" />
    <parent link="post" />
    <child link="cap" />
    <axis xyz="0 0 1" />
    <limit effort="2" velocity="4" />
    </joint>
  </robot>
