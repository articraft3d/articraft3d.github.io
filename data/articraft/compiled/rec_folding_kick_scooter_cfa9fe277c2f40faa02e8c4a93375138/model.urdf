  <joint name="deck_to_front_wheel" type="continuous">
    <origin xyz="0.465 0 0.105" rpy="0 0 0" />
    <parent link="deck" />
    <child link="front_wheel" />
    <axis xyz="0 1 0" />
    <limit effort="60" velocity="30" />
    </joint>
  <joint name="deck_to_rear_wheel" type="continuous">
    <origin xyz="-0.505 0 0.105" rpy="0 0 0" />
    <parent link="deck" />
    <child link="rear_wheel" />
    <axis xyz="0 1 0" />
    <limit effort="25" velocity="30" />
    </joint>
  <joint name="deck_to_lower_stem" type="revolute">
    <origin xyz="0.3 0 0.229" rpy="0 0 0" />
    <parent link="deck" />
    <child link="lower_stem" />
    <axis xyz="0 -1 0" />
    <limit effort="80" velocity="1.5" lower="0" upper="1.55" />
    </joint>
  <joint name="lower_stem_to_upper_stem" type="prismatic">
    <origin xyz="0 0 0.52" rpy="0 0 0" />
    <parent link="lower_stem" />
    <child link="upper_stem" />
    <axis xyz="0 0 1" />
    <limit effort="120" velocity="0.35" lower="0" upper="0.2" />
    </joint>
  <joint name="deck_to_brake_pad" type="revolute">
    <origin xyz="-0.41 0 0.232" rpy="0 0 0" />
    <parent link="deck" />
    <child link="brake_pad" />
    <axis xyz="0 -1 0" />
    <limit effort="25" velocity="2" lower="0" upper="0.24" />
    </joint>
  </robot>
