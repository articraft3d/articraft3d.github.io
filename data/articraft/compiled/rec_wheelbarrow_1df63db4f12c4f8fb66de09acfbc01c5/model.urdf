  <joint name="frame_to_tray" type="fixed">
    <parent link="frame" />
    <child link="tray" />
    </joint>
  <joint name="frame_to_wheel" type="continuous">
    <origin xyz="-0.735 0 0.205" rpy="0 0 0" />
    <parent link="frame" />
    <child link="wheel" />
    <axis xyz="0 1 0" />
    <limit effort="18" velocity="18" />
    <dynamics damping="0.02" friction="0.01" />
    </joint>
  <joint name="frame_to_rear_stand" type="revolute">
    <origin xyz="0.72 0 0.505" rpy="0 0 0" />
    <parent link="frame" />
    <child link="rear_stand" />
    <axis xyz="0 -1 0" />
    <limit effort="35" velocity="1.6" lower="0" upper="1.35" />
    <dynamics damping="0.35" friction="0.1" />
    </joint>
  </robot>
