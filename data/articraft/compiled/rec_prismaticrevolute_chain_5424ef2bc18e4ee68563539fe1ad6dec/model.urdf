  <joint name="guide_slide" type="prismatic">
    <origin xyz="-0.22 0 0.095" rpy="0 0 0" />
    <parent link="base_guide" />
    <child link="carriage" />
    <axis xyz="1 0 0" />
    <limit effort="120" velocity="0.35" lower="0" upper="0.34" />
    </joint>
  <joint name="output_pin" type="revolute">
    <origin xyz="0.155 0 0" rpy="0 0 0" />
    <parent link="carriage" />
    <child link="output_link" />
    <axis xyz="0 0 1" />
    <limit effort="25" velocity="2" lower="-1.25" upper="1.25" />
    </joint>
  </robot>
