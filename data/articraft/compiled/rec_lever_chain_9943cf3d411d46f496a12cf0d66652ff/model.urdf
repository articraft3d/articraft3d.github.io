<robot name="three_link_lever_chain">
  <material name="blackened_base">
    <color rgba="0.08 0.09 0.1 1" />
    </material>
  <material name="brushed_steel">
    <color rgba="0.72 0.74 0.72 1" />
    </material>
  <material name="blue_steel_links">
    <color rgba="0.12 0.3 0.62 1" />
    </material>
  <material name="zinc_upper_link">
