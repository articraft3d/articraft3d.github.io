    <visual name="foot_bolt_1">
      <origin xyz="-0.095 0.032 -0.0375" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.006" length="0.003" />
        </geometry>
      <material name="dark_bolt_heads">
        <color rgba="0.02 0.02 0.018 1" />
        </material>
      </visual>
    <collision name="mount_foot">
      <origin xyz="-0.045 0 -0.045" rpy="0 0 0" />
      <geometry>
        <box size="0.16 0.1 0.012" />
        </geometry>
      </collision>
    <collision name="round_lug">
      <origin xyz="0 0 -0.023" rpy="0 0 0" />
      <geometry>
