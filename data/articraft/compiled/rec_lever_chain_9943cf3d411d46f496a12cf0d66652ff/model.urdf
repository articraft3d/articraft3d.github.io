  <link name="lever_1">
    <visual name="lever_1_plate">
      <origin xyz="0 0 0.0075" rpy="0 0 0" />
      <geometry>
        <mesh filename="assets/meshes/lever_1_plate.obj" />
        </geometry>
      <material name="zinc_upper_link">
