  <joint name="base_to_lever_0" type="revolute">
    <parent link="base_lug" />
    <child link="lever_0" />
    <axis xyz="0 0 1" />
    <limit effort="12" velocity="4" lower="-1.35" upper="1.35" />
    </joint>
  <joint name="lever_0_to_lever_1" type="revolute">
    <origin xyz="0.18 0 0" rpy="0 0 0" />
    <parent link="lever_0" />
    <child link="lever_1" />
    <axis xyz="0 0 1" />
    <limit effort="10" velocity="4" lower="-2.1" upper="2.1" />
    </joint>
  <joint name="lever_1_to_lever_2" type="revolute">
