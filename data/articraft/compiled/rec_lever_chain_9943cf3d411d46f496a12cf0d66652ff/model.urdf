      </collision>
    <collision name="foot_bolt_0">
      <origin xyz="-0.095 -0.032 -0.0375" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.006" length="0.003" />
        </geometry>
      </collision>
    <collision name="foot_bolt_1">
