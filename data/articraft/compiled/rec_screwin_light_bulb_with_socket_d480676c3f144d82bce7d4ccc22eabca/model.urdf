<robot name="premium_screw_in_bulb_socket">
  <material name="frosted_glass">
    <color rgba="0.92 0.96 1 0.48" />
    </material>
  <material name="warm_inner_glow">
    <color rgba="1 0.86 0.54 0.34" />
    </material>
  <material name="satin_nickel">
    <color rgba="0.78 0.75 0.68 1" />
    </material>
  <material name="painted_warm_white_metal">
    <color rgba="0.82 0.8 0.74 1" />
    </material>
  <material name="charcoal_polymer">
    <color rgba="0.035 0.037 0.04 1" />
    </material>
  <material name="black_elastomer">
    <color rgba="0.006 0.006 0.006 1" />
    </material>
  <material name="brushed_brass_contact">
    <color rgba="0.95 0.69 0.28 1" />
    </material>
  <link name="socket">
    <visual name="socket_shell">
      <geometry>
        <mesh filename="assets/meshes/socket_shell.obj" />
        </geometry>
      <material name="painted_warm_white_metal">
        <color rgba="0.82 0.8 0.74 1" />
        </material>
      </visual>
    <visual name="socket_liner">
      <geometry>
        <mesh filename="assets/meshes/socket_liner.obj" />
        </geometry>
      <material name="charcoal_polymer">
        <color rgba="0.035 0.037 0.04 1" />
        </material>
      </visual>
    <visual name="socket_internal_thread">
      <geometry>
        <mesh filename="assets/meshes/socket_internal_thread.obj" />
        </geometry>
      <material name="brushed_brass_contact">
        <color rgba="0.95 0.69 0.28 1" />
        </material>
      </visual>
    <visual name="socket_floor">
      <origin xyz="0 0 0.0125" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0142" length="0.005" />
        </geometry>
      <material name="charcoal_polymer">
        <color rgba="0.035 0.037 0.04 1" />
        </material>
      </visual>
    <visual name="center_contact">
      <origin xyz="0 0 0.016" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0062" length="0.003" />
        </geometry>
      <material name="brushed_brass_contact">
        <color rgba="0.95 0.69 0.28 1" />
        </material>
      </visual>
    <visual name="base_gasket">
      <origin xyz="0 0 0.0032" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0305" length="0.0032" />
        </geometry>
      <material name="black_elastomer">
        <color rgba="0.006 0.006 0.006 1" />
        </material>
      </visual>
    <collision name="socket_shell">
      <geometry>
        <mesh filename="assets/meshes/socket_shell.obj" />
        </geometry>
      </collision>
    <collision name="socket_liner">
      <geometry>
        <mesh filename="assets/meshes/socket_liner.obj" />
        </geometry>
      </collision>
    <collision name="socket_internal_thread">
      <geometry>
        <mesh filename="assets/meshes/socket_internal_thread.obj" />
        </geometry>
      </collision>
    <collision name="socket_floor">
      <origin xyz="0 0 0.0125" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0142" length="0.005" />
        </geometry>
      </collision>
    <collision name="center_contact">
      <origin xyz="0 0 0.016" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0062" length="0.003" />
        </geometry>
      </collision>
    <collision name="base_gasket">
      <origin xyz="0 0 0.0032" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0305" length="0.0032" />
        </geometry>
      </collision>
    </link>
  <link name="thread_axis" />
  <link name="bulb">
    <visual name="glass_shell">
      <geometry>
        <mesh filename="assets/meshes/glass_shell.obj" />
        </geometry>
      <material name="frosted_glass">
        <color rgba="0.92 0.96 1 0.48" />
        </material>
      </visual>
    <visual name="glow_stem">
      <origin xyz="0 0 0.126" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.003" length="0.086" />
        </geometry>
      <material name="warm_inner_glow">
        <color rgba="1 0.86 0.54 0.34" />
        </material>
      </visual>
    <visual name="screw_core">
      <geometry>
        <mesh filename="assets/meshes/screw_core.obj" />
        </geometry>
      <material name="satin_nickel">
        <color rgba="0.78 0.75 0.68 1" />
        </material>
      </visual>
    <visual name="external_thread">
      <geometry>
        <mesh filename="assets/meshes/external_thread.obj" />
        </geometry>
      <material name="satin_nickel">
        <color rgba="0.78 0.75 0.68 1" />
        </material>
      </visual>
    <visual name="neck_seal">
      <origin xyz="0 0 0.0834" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0122" length="0.0055" />
        </geometry>
      <material name="black_elastomer">
        <color rgba="0.006 0.006 0.006 1" />
        </material>
      </visual>
    <visual name="tip_contact">
      <origin xyz="0 0 0.021" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0056" length="0.007" />
        </geometry>
      <material name="brushed_brass_contact">
        <color rgba="0.95 0.69 0.28 1" />
        </material>
      </visual>
    <collision name="glass_shell">
      <geometry>
        <mesh filename="assets/meshes/glass_shell.obj" />
        </geometry>
      </collision>
    <collision name="glow_stem">
      <origin xyz="0 0 0.126" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.003" length="0.086" />
        </geometry>
      </collision>
    <collision name="screw_core">
      <geometry>
        <mesh filename="assets/meshes/screw_core.obj" />
        </geometry>
      </collision>
    <collision name="external_thread">
      <geometry>
        <mesh filename="assets/meshes/external_thread.obj" />
        </geometry>
      </collision>
    <collision name="neck_seal">
      <origin xyz="0 0 0.0834" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0122" length="0.0055" />
        </geometry>
      </collision>
    <collision name="tip_contact">
      <origin xyz="0 0 0.021" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0056" length="0.007" />
        </geometry>
      </collision>
    </link>
  <joint name="screw_turn" type="revolute">
    <parent link="thread_axis" />
    <child link="bulb" />
    <axis xyz="0 0 1" />
    <limit effort="0.8" velocity="2.6" lower="0" upper="15.708" />
    <dynamics damping="0.03" friction="0.05" />
    </joint>
  <joint name="screw_lift" type="prismatic">
    <parent link="socket" />
    <child link="thread_axis" />
    <axis xyz="0 0 1" />
    <limit effort="12" velocity="0.05" lower="0" upper="0.009075" />
    <dynamics damping="0.05" friction="0.08" />
    </joint>
  </robot>
