  <joint name="root_to_upper" type="revolute">
    <parent link="root_support" />
    <child link="upper_link" />
    <axis xyz="0 -1 0" />
    <limit effort="90" velocity="1.5" lower="-0.75" upper="1.25" />
    <dynamics damping="0.4" friction="0.05" />
    </joint>
  <joint name="upper_to_forelink" type="revolute">
    <origin xyz="0.62 0 0" rpy="0 0 0" />
    <parent link="upper_link" />
    <child link="forelink" />
    <axis xyz="0 -1 0" />
    <limit effort="70" velocity="1.8" lower="-1.25" upper="1.4" />
    <dynamics damping="0.35" friction="0.04" />
    </joint>
  <joint name="forelink_to_runner" type="prismatic">
    <origin xyz="0.5 0 0" rpy="0 0 0" />
    <parent link="forelink" />
    <child link="runner" />
    <axis xyz="1 0 0" />
    <limit effort="55" velocity="0.45" lower="0" upper="0.16" />
    <dynamics damping="0.25" friction="0.08" />
    </joint>
