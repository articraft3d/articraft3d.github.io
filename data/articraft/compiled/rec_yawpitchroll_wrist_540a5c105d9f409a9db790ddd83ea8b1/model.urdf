  <joint name="yaw" type="revolute">
    <origin xyz="0 0 0.205" rpy="0 0 0" />
    <parent link="body" />
    <child link="yaw_stage" />
    <axis xyz="0 0 1" />
    <limit effort="120" velocity="1.5" lower="-3.14159" upper="3.14159" />
    </joint>
  <joint name="pitch" type="revolute">
    <origin xyz="0.165 0 0.225" rpy="0 0 0" />
    <parent link="yaw_stage" />
    <child link="pitch_cradle" />
    <axis xyz="0 -1 0" />
    <limit effort="85" velocity="1.2" lower="-1.25" upper="1.25" />
    </joint>
  <joint name="roll" type="revolute">
    <origin xyz="0.255 0 0" rpy="0 0 0" />
    <parent link="pitch_cradle" />
    <child link="roll_flange" />
    <axis xyz="1 0 0" />
    <limit effort="45" velocity="2.5" lower="-3.14159" upper="3.14159" />
    </joint>
