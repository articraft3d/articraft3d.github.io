  <joint name="base_to_speed_dial" type="revolute">
    <origin xyz="0 -0.121 0.083" rpy="0 0 0" />
    <parent link="base" />
    <child link="speed_dial" />
    <axis xyz="0 -1 0" />
    <limit effort="0.5" velocity="2" lower="-2.35" upper="2.35" />
    </joint>
  <joint name="base_to_jar_bayonet" type="revolute">
