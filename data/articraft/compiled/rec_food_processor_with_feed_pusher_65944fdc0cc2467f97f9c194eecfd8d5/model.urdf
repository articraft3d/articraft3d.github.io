  <joint name="base_to_bowl" type="continuous">
    <origin xyz="0 0 0.085" rpy="0 0 0" />
    <parent link="base" />
    <child link="bowl" />
    <axis xyz="0 0 1" />
    <limit effort="8" velocity="1.2" />
    </joint>
