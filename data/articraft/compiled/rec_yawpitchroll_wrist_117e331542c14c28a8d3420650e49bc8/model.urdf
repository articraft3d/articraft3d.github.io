  <joint name="housing_to_yaw" type="revolute">
    <origin xyz="0 0 0.18" rpy="0 0 0" />
    <parent link="housing" />
    <child link="yaw_stage" />
    <axis xyz="0 0 1" />
    <limit effort="80" velocity="1.5" lower="-3.14159" upper="3.14159" />
    </joint>
  <joint name="yaw_to_pitch" type="revolute">
    <origin xyz="0.16 0 0.17" rpy="0 0 0" />
    <parent link="yaw_stage" />
    <child link="pitch_support" />
    <axis xyz="0 -1 0" />
    <limit effort="55" velocity="1.2" lower="-0.85" upper="0.85" />
    </joint>
  <joint name="pitch_to_roll" type="revolute">
    <origin xyz="0.225 0 0" rpy="0 0 0" />
    <parent link="pitch_support" />
    <child link="roll_cartridge" />
    <axis xyz="1 0 0" />
    <limit effort="30" velocity="2.5" lower="-3.14159" upper="3.14159" />
    </joint>
  </robot>
