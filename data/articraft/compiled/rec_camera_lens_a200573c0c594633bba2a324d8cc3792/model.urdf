        </geometry>
      <material name="engraved_white_marking">
        <color rgba="0.92 0.93 0.88 1" />
        </material>
      </visual>
    <visual name="bearing_ball_0">
      <origin xyz="0.06525 0 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.00125" />
        </geometry>
      <material name="dark_anodized_metal">
        <color rgba="0.12 0.13 0.14 1" />
        </material>
      </visual>
    <visual name="bearing_ball_1">
      <origin xyz="-0.06525 0 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.00125" />
        </geometry>
      <material name="dark_anodized_metal">
        <color rgba="0.12 0.13 0.14 1" />
        </material>
      </visual>
    <visual name="bearing_ball_2">
      <origin xyz="0 0.06525 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.00125" />
        </geometry>
      <material name="dark_anodized_metal">
        <color rgba="0.12 0.13 0.14 1" />
        </material>
      </visual>
    <visual name="bearing_ball_3">
      <origin xyz="0 -0.06525 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.00125" />
        </geometry>
      <material name="dark_anodized_metal">
        <color rgba="0.12 0.13 0.14 1" />
        </material>
      </visual>
    <collision name="collar_shell">
      <geometry>
        <mesh filename="assets/meshes/rotation_collar_shell.obj" />
        </geometry>
      </collision>
    <collision name="collar_index_mark">
      <origin xyz="0 0.0757 -0.018" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.0015" />
        </geometry>
      </collision>
    <collision name="bearing_ball_0">
      <origin xyz="0.06525 0 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.00125" />
        </geometry>
      </collision>
    <collision name="bearing_ball_1">
      <origin xyz="-0.06525 0 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.00125" />
        </geometry>
      </collision>
    <collision name="bearing_ball_2">
      <origin xyz="0 0.06525 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.00125" />
        </geometry>
      </collision>
    <collision name="bearing_ball_3">
      <origin xyz="0 -0.06525 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.00125" />
        </geometry>
      </collision>
    </link>
  <link name="shift_carriage">
    <visual name="shift_saddle">
      <geometry>
        <mesh filename="assets/meshes/shift_saddle_ring.obj" />
        </geometry>
      <material name="dark_anodized_metal">
        <color rgba="0.12 0.13 0.14 1" />
        </material>
      </visual>
    <visual name="guide_shoe_0">
      <origin xyz="0 0.0538 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.0022" />
        </geometry>
      <material name="dark_anodized_metal">
        <color rgba="0.12 0.13 0.14 1" />
        </material>
      </visual>
    <visual name="guide_shoe_1">
      <origin xyz="0 -0.0538 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.0022" />
        </geometry>
      <material name="dark_anodized_metal">
        <color rgba="0.12 0.13 0.14 1" />
        </material>
      </visual>
    <collision name="shift_saddle">
      <geometry>
        <mesh filename="assets/meshes/shift_saddle_ring.obj" />
        </geometry>
      </collision>
    <collision name="guide_shoe_0">
      <origin xyz="0 0.0538 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.0022" />
        </geometry>
      </collision>
    <collision name="guide_shoe_1">
      <origin xyz="0 -0.0538 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.0022" />
        </geometry>
      </collision>
    </link>
  <link name="optical_block">
    <visual name="optical_barrel">
      <geometry>
        <mesh filename="assets/meshes/optical_block_barrel.obj" />
        </geometry>
      <material name="matte_black">
        <color rgba="0.015 0.016 0.018 1" />
        </material>
      </visual>
    <visual name="front_glass">
      <origin xyz="0 0 0.044" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.02" length="0.004" />
        </geometry>
      <material name="coated_glass_blue">
        <color rgba="0.25 0.48 0.68 0.48" />
        </material>
      </visual>
    <visual name="rear_glass">
      <origin xyz="0 0 -0.037" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.014" length="0.0035" />
        </geometry>
      <material name="coated_glass_green">
        <color rgba="0.18 0.55 0.45 0.42" />
        </material>
      </visual>
    <visual name="tilt_trunnion">
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.0032" length="0.068" />
        </geometry>
      <material name="dark_anodized_metal">
        <color rgba="0.12 0.13 0.14 1" />
        </material>
      </visual>
    <collision name="optical_barrel">
      <geometry>
        <mesh filename="assets/meshes/optical_block_barrel.obj" />
        </geometry>
      </collision>
    <collision name="front_glass">
      <origin xyz="0 0 0.044" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.02" length="0.004" />
        </geometry>
      </collision>
    <collision name="rear_glass">
      <origin xyz="0 0 -0.037" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.014" length="0.0035" />
        </geometry>
      </collision>
    <collision name="tilt_trunnion">
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.0032" length="0.068" />
        </geometry>
      </collision>
    </link>
  <joint name="collar_rotation" type="revolute">
    <parent link="outer_housing" />
    <child link="rotation_collar" />
    <axis xyz="0 0 1" />
    <limit effort="1.5" velocity="2" lower="-3.14159" upper="3.14159" />
    </joint>
  <joint name="block_shift" type="prismatic">
    <parent link="rotation_collar" />
    <child link="shift_carriage" />
    <axis xyz="1 0 0" />
    <limit effort="12" velocity="0.08" lower="-0.012" upper="0.012" />
    </joint>
  <joint name="block_tilt" type="revolute">
    <parent link="shift_carriage" />
    <child link="optical_block" />
    <axis xyz="0 1 0" />
    <limit effort="3" velocity="0.6" lower="-0.15" upper="0.15" />
    </joint>
  </robot>
