<robot name="tilt_shift_architectural_prime_lens">
  <material name="matte_black">
    <color rgba="0.015 0.016 0.018 1" />
    </material>
  <material name="satin_black">
    <color rgba="0.04 0.045 0.05 1" />
    </material>
  <material name="ribbed_rubber">
    <color rgba="0.008 0.008 0.009 1" />
    </material>
  <material name="dark_anodized_metal">
    <color rgba="0.12 0.13 0.14 1" />
    </material>
  <material name="engraved_white_marking">
    <color rgba="0.92 0.93 0.88 1" />
    </material>
  <material name="mount_red_dot">
    <color rgba="0.78 0.02 0.015 1" />
    </material>
  <material name="coated_glass_blue">
    <color rgba="0.25 0.48 0.68 0.48" />
    </material>
  <material name="coated_glass_green">
    <color rgba="0.18 0.55 0.45 0.42" />
    </material>
  <link name="outer_housing">
    <visual name="barrel_shell">
      <geometry>
        <mesh filename="assets/meshes/outer_housing_shell.obj" />
        </geometry>
      <material name="satin_black">
        <color rgba="0.04 0.045 0.05 1" />
        </material>
      </visual>
    <visual name="mount_index_dot">
      <origin xyz="0 0.053 0.055" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.0016" />
        </geometry>
      <material name="mount_red_dot">
        <color rgba="0.78 0.02 0.015 1" />
        </material>
      </visual>
    <collision name="barrel_shell">
      <geometry>
        <mesh filename="assets/meshes/outer_housing_shell.obj" />
        </geometry>
      </collision>
    <collision name="mount_index_dot">
      <origin xyz="0 0.053 0.055" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.0016" />
        </geometry>
      </collision>
    </link>
  <link name="rotation_collar">
