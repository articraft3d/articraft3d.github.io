    <child link="arm" />
    <axis xyz="0 -1 0" />
    <limit effort="18" velocity="0.8" lower="-0.28" upper="0.42" />
    </joint>
  <joint name="arm_to_shade" type="fixed">
    <origin xyz="1.62 0 -0.11" rpy="0 0 0" />
