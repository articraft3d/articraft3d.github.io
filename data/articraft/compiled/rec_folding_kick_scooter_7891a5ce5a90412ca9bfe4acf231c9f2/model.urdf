  <joint name="steering" type="continuous">
    <origin xyz="0.335 0 0.245" rpy="0 0 0" />
    <parent link="deck" />
    <child link="front_fork" />
    <axis xyz="0 0 1" />
    <limit effort="12" velocity="5" />
    </joint>
  <joint name="folding_hinge" type="revolute">
    <origin xyz="-0.043 0 0.147" rpy="0 0 0" />
    <parent link="front_fork" />
    <child link="stem" />
    <axis xyz="0 -1 0" />
    <limit effort="30" velocity="1.8" lower="0" upper="1.62" />
    </joint>
  <joint name="front_wheel_spin" type="continuous">
    <origin xyz="0.07 0 -0.18" rpy="0 0 0" />
    <parent link="front_fork" />
    <child link="front_wheel" />
    <axis xyz="0 1 0" />
    <limit effort="2" velocity="40" />
    </joint>
  <joint name="rear_wheel_spin" type="continuous">
    <origin xyz="-0.385 0 0.055" rpy="0 0 0" />
    <parent link="deck" />
    <child link="rear_wheel" />
    <axis xyz="0 1 0" />
    <limit effort="2" velocity="40" />
    </joint>
  </robot>
