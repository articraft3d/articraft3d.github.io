      <origin xyz="0 0 0" rpy="0 0 1.5708" />
      <geometry>
        <mesh filename="assets/meshes/front_tire.obj" />
        </geometry>
      <material name="black_rubber">
        <color rgba="0.015 0.014 0.012 1" />
        </material>
      </visual>
    <visual name="rim">
      <origin xyz="0 0 0" rpy="0 0 1.5708" />
      <geometry>
        <mesh filename="assets/meshes/front_rim.obj" />
        </geometry>
      <material name="brushed_aluminum">
        <color rgba="0.72 0.74 0.72 1" />
        </material>
      </visual>
    <collision name="tire">
      <origin xyz="0 0 0" rpy="0 0 1.5708" />
      <geometry>
        <mesh filename="assets/meshes/front_tire.obj" />
        </geometry>
      </collision>
    <collision name="rim">
      <origin xyz="0 0 0" rpy="0 0 1.5708" />
      <geometry>
        <mesh filename="assets/meshes/front_rim.obj" />
        </geometry>
      </collision>
    </link>
  <joint name="deck_to_steering" type="revolute">
    <origin xyz="0.3 0 0.205" rpy="0 0 0" />
    <parent link="deck" />
    <child link="steering" />
    <axis xyz="-0.116029 0 0.993246" />
    <limit effort="18" velocity="3.5" lower="-0.7" upper="0.7" />
    </joint>
  <joint name="deck_to_brake" type="revolute">
    <origin xyz="-0.33 0 0.176" rpy="0 0 0" />
    <parent link="deck" />
    <child link="brake" />
    <axis xyz="0 1 0" />
    <limit effort="8" velocity="2" lower="-0.28" upper="0.04" />
    </joint>
  <joint name="deck_to_rear_wheel" type="continuous">
    <origin xyz="-0.39 0 0.09" rpy="0 0 0" />
    <parent link="deck" />
    <child link="rear_wheel" />
    <axis xyz="0 1 0" />
    <limit effort="3" velocity="40" />
    </joint>
  <joint name="steering_to_front_wheel" type="continuous">
    <origin xyz="0.12 0 -0.115" rpy="0 0 0" />
    <parent link="steering" />
    <child link="front_wheel" />
    <axis xyz="0 1 0" />
    <limit effort="3" velocity="40" />
    </joint>
  </robot>
