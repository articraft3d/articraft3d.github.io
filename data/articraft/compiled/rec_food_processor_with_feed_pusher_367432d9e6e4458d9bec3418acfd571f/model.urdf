      <origin xyz="0 -0.0085 0" rpy="0 0 0" />
      <geometry>
        <box size="0.044 0.016 0.03" />
        </geometry>
      </collision>
    </link>
  <joint name="base_to_bowl" type="continuous">
    <origin xyz="0 0 0.22" rpy="0 0 0" />
    <parent link="motor_base" />
    <child link="work_bowl" />
    <axis xyz="0 0 1" />
    <limit effort="20" velocity="1" />
    </joint>
  <joint name="base_to_shaft" type="fixed">
    <origin xyz="0 0 0.22" rpy="0 0 0" />
    <parent link="motor_base" />
    <child link="center_shaft" />
    </joint>
  <joint name="shaft_to_blade" type="continuous">
    <origin xyz="0 0 0.086" rpy="0 0 0" />
    <parent link="center_shaft" />
    <child link="blade_hub" />
    <axis xyz="0 0 1" />
    <limit effort="12" velocity="25" />
    </joint>
  <joint name="bowl_to_lid" type="fixed">
    <origin xyz="0 0 0.235" rpy="0 0 0" />
    <parent link="work_bowl" />
    <child link="lid" />
    </joint>
  <joint name="lid_to_chute" type="fixed">
    <origin xyz="0.055 -0.04 0.018" rpy="0 0 0" />
    <parent link="lid" />
    <child link="feed_chute" />
    </joint>
  <joint name="chute_to_pusher" type="prismatic">
    <parent link="feed_chute" />
    <child link="pusher" />
    <axis xyz="0 0 1" />
    <limit effort="18" velocity="0.25" lower="0" upper="0.075" />
    </joint>
  <joint name="base_to_knob" type="continuous">
    <origin xyz="0 -0.173 0.105" rpy="0 0 0" />
    <parent link="motor_base" />
    <child link="speed_knob" />
    <axis xyz="0 -1 0" />
    <limit effort="0.8" velocity="6" />
    </joint>
  <joint name="base_to_button_0" type="prismatic">
    <origin xyz="-0.078 -0.171 0.105" rpy="0 0 0" />
    <parent link="motor_base" />
    <child link="pulse_button_0" />
    <axis xyz="0 1 0" />
    <limit effort="6" velocity="0.2" lower="0" upper="0.01" />
    </joint>
  <joint name="base_to_button_1" type="prismatic">
    <origin xyz="0.078 -0.171 0.105" rpy="0 0 0" />
    <parent link="motor_base" />
    <child link="pulse_button_1" />
    <axis xyz="0 1 0" />
    <limit effort="6" velocity="0.2" lower="0" upper="0.01" />
    </joint>
  </robot>
