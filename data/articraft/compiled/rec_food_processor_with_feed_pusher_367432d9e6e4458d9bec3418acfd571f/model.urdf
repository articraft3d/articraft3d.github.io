      <geometry>
        <mesh filename="assets/meshes/pusher_sleeve.obj" />
        </geometry>
      </collision>
    </link>
  <link name="speed_knob">
    <visual name="knob_cap">
      <origin xyz="0 -0.015 0" rpy="1.5708 0 0" />
      <geometry>
        <mesh filename="assets/meshes/speed_selector_knob.obj" />
        </geometry>
      <material name="dark_plastic">
        <color rgba="0.035 0.037 0.04 1" />
        </material>
      </visual>
    <collision name="knob_cap">
      <origin xyz="0 -0.015 0" rpy="1.5708 0 0" />
      <geometry>
        <mesh filename="assets/meshes/speed_selector_knob.obj" />
        </geometry>
      </collision>
    </link>
  <link name="pulse_button_0">
    <visual name="button_cap">
      <origin xyz="0 -0.0085 0" rpy="0 0 0" />
      <geometry>
        <box size="0.044 0.016 0.03" />
        </geometry>
      <material name="red_pulse">
        <color rgba="0.74 0.07 0.045 1" />
        </material>
      </visual>
    <collision name="button_cap">
      <origin xyz="0 -0.0085 0" rpy="0 0 0" />
      <geometry>
        <box size="0.044 0.016 0.03" />
        </geometry>
      </collision>
    </link>
  <link name="pulse_button_1">
    <visual name="button_cap">
      <origin xyz="0 -0.0085 0" rpy="0 0 0" />
      <geometry>
        <box size="0.044 0.016 0.03" />
        </geometry>
      <material name="red_pulse">
        <color rgba="0.74 0.07 0.045 1" />
        </material>
      </visual>
