<robot name="premium_swivel_bar_stool">
  <material name="satin_graphite_painted_metal">
    <color rgba="0.055 0.058 0.06 1" />
    </material>
  <material name="brushed_steel_bearing">
    <color rgba="0.62 0.64 0.63 1" />
    </material>
  <material name="black_molded_polymer">
    <color rgba="0.018 0.019 0.02 1" />
    </material>
  <material name="warm_black_leather">
    <color rgba="0.045 0.036 0.03 1" />
    </material>
  <material name="subtle_leather_seam">
    <color rgba="0.025 0.02 0.017 1" />
    </material>
  <material name="soft_floor_elastomer">
    <color rgba="0.012 0.012 0.011 1" />
    </material>
  <link name="pedestal">
    <visual name="painted_frame">
      <geometry>
        <mesh filename="assets/meshes/pedestal_metal.obj" />
        </geometry>
      <material name="satin_graphite_painted_metal">
        <color rgba="0.055 0.058 0.06 1" />
        </material>
      </visual>
    <visual name="lower_race">
      <geometry>
        <mesh filename="assets/meshes/lower_bearing_race.obj" />
        </geometry>
      <material name="brushed_steel_bearing">
        <color rgba="0.62 0.64 0.63 1" />
        </material>
      </visual>
    <collision name="painted_frame">
      <geometry>
        <mesh filename="assets/meshes/pedestal_metal.obj" />
        </geometry>
      </collision>
    <collision name="lower_race">
      <geometry>
        <mesh filename="assets/meshes/lower_bearing_race.obj" />
        </geometry>
      </collision>
    </link>
  <link name="floor_gasket">
    <visual name="rubber_ring">
      <geometry>
        <mesh filename="assets/meshes/floor_gasket.obj" />
        </geometry>
      <material name="soft_floor_elastomer">
        <color rgba="0.012 0.012 0.011 1" />
        </material>
      </visual>
    <collision name="rubber_ring">
      <geometry>
        <mesh filename="assets/meshes/floor_gasket.obj" />
        </geometry>
      </collision>
    </link>
  <link name="seat_stage">
    <visual name="upper_race">
      <geometry>
        <mesh filename="assets/meshes/seat_swivel_metal.obj" />
        </geometry>
      <material name="satin_graphite_painted_metal">
        <color rgba="0.055 0.058 0.06 1" />
        </material>
      </visual>
    <visual name="polymer_pan">
      <geometry>
        <mesh filename="assets/meshes/molded_seat_pan.obj" />
        </geometry>
      <material name="black_molded_polymer">
        <color rgba="0.018 0.019 0.02 1" />
        </material>
      </visual>
    <visual name="cushion">
      <geometry>
        <mesh filename="assets/meshes/rounded_cushion.obj" />
        </geometry>
      <material name="warm_black_leather">
        <color rgba="0.045 0.036 0.03 1" />
        </material>
      </visual>
    <visual name="seam_cord">
      <geometry>
        <mesh filename="assets/meshes/cushion_seam.obj" />
        </geometry>
      <material name="subtle_leather_seam">
        <color rgba="0.025 0.02 0.017 1" />
        </material>
      </visual>
    <collision name="upper_race">
      <geometry>
        <mesh filename="assets/meshes/seat_swivel_metal.obj" />
        </geometry>
      </collision>
    <collision name="polymer_pan">
      <geometry>
        <mesh filename="assets/meshes/molded_seat_pan.obj" />
        </geometry>
      </collision>
    <collision name="cushion">
      <geometry>
        <mesh filename="assets/meshes/rounded_cushion.obj" />
        </geometry>
      </collision>
    <collision name="seam_cord">
      <geometry>
        <mesh filename="assets/meshes/cushion_seam.obj" />
        </geometry>
      </collision>
    </link>
  <joint name="pedestal_to_floor_gasket" type="fixed">
    <parent link="pedestal" />
    <child link="floor_gasket" />
    </joint>
  <joint name="seat_swivel" type="continuous">
    <origin xyz="0 0 0.604" rpy="0 0 0" />
    <parent link="pedestal" />
    <child link="seat_stage" />
    <axis xyz="0 0 1" />
    <limit effort="18" velocity="4" />
    <dynamics damping="0.08" friction="0.18" />
    </joint>
  </robot>
