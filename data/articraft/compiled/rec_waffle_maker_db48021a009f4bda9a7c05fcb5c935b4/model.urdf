    </link>
  <joint name="rear_hinge" type="revolute">
    <origin xyz="-0.16 0 0.105" rpy="0 0 0" />
    <parent link="lower_body" />
    <child link="upper_shell" />
    <axis xyz="0 -1 0" />
    <limit effort="18" velocity="1.6" lower="0" upper="1.25" />
    </joint>
  <joint name="dial_spin" type="continuous">
    <origin xyz="0.075 0.172 0.036" rpy="0 0 0" />
    <parent link="lower_body" />
    <child link="dial" />
    <axis xyz="0 1 0" />
    <limit effort="0.25" velocity="5" />
    </joint>
  </robot>
