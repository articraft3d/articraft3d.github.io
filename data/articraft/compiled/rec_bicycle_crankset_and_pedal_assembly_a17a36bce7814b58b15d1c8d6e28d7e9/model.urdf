  <joint name="bottom_bracket_to_crankset" type="revolute">
    <parent link="bottom_bracket" />
    <child link="crankset" />
    <axis xyz="1 0 0" />
    <limit effort="130" velocity="14" lower="-3.14159" upper="3.14159" />
    </joint>
