      <origin xyz="0 0 0.016" rpy="0 0 0" />
      <geometry>
        <mesh filename="assets/meshes/outer_link_plate.obj" />
        </geometry>
      <material name="satin_ground_steel">
        <color rgba="0.56 0.58 0.57 1" />
        </material>
      </visual>
    <visual name="joint_boss">
      <origin xyz="0 0 0.021" rpy="0 0 0" />
