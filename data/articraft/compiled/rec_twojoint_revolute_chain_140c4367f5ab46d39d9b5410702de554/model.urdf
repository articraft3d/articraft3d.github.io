      <geometry>
        <mesh filename="assets/meshes/outer_link_end_tab_pad.obj" />
        </geometry>
      </collision>
    </link>
  <joint name="cheek_to_inner" type="revolute">
    <parent link="fixed_cheek" />
    <child link="inner_link" />
    <axis xyz="0 0 1" />
    <limit effort="8" velocity="2.5" lower="-1.35" upper="1.35" />
    </joint>
  <joint name="inner_to_outer" type="revolute">
    <origin xyz="0.3 0 0" rpy="0 0 0" />
    <parent link="inner_link" />
    <child link="outer_link" />
    <axis xyz="0 0 1" />
    <limit effort="6" velocity="2.5" lower="-1.6" upper="1.6" />
    </joint>
  </robot>
