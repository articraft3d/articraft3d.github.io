  <joint name="head_tilt" type="revolute">
    <origin xyz="-0.105 0 0.38" rpy="0 0 0" />
    <parent link="base" />
    <child link="head" />
    <axis xyz="0 -1 0" />
    <limit effort="20" velocity="1.2" lower="0" upper="0.95" />
    </joint>
  <joint name="bowl_slide" type="prismatic">
    <origin xyz="0.02 0 0.078" rpy="0 0 0" />
    <parent link="base" />
    <child link="bowl_carriage" />
    <axis xyz="1 0 0" />
    <limit effort="45" velocity="0.2" lower="0" upper="0.075" />
    </joint>
  <joint name="whisk_spin" type="continuous">
    <origin xyz="0.245 0 -0.096" rpy="0 0 0" />
