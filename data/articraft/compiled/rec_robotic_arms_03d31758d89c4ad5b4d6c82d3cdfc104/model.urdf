  <joint name="base_to_turret" type="revolute">
    <origin xyz="0 0 0.73" rpy="0 0 0" />
    <parent link="base" />
    <child link="turret" />
    <axis xyz="0 0 1" />
    <limit effort="900" velocity="1.2" lower="-3.14159" upper="3.14159" />
    <dynamics damping="8" friction="2" />
    </joint>
  <joint name="turret_to_upper_arm" type="revolute">
    <origin xyz="0 0 0.62" rpy="0 0 0" />
    <parent link="turret" />
    <child link="upper_arm" />
    <axis xyz="0 -1 0" />
    <limit effort="1250" velocity="0.9" lower="-0.95" upper="1.15" />
    <dynamics damping="10" friction="3" />
    </joint>
  <joint name="upper_arm_to_forearm" type="revolute">
    <origin xyz="1.05 0 0.05" rpy="0 0 0" />
    <parent link="upper_arm" />
    <child link="forearm" />
    <axis xyz="0 -1 0" />
    <limit effort="950" velocity="1.1" lower="-1.25" upper="1.35" />
    <dynamics damping="8" friction="2.5" />
    </joint>
  <joint name="forearm_to_wrist" type="revolute">
    <origin xyz="0.84 0 0" rpy="0 0 0" />
    <parent link="forearm" />
    <child link="wrist" />
    <axis xyz="0 -1 0" />
    <limit effort="360" velocity="1.8" lower="-1.55" upper="1.55" />
    <dynamics damping="5" friction="1.2" />
    </joint>
  <joint name="wrist_to_tool_flange" type="revolute">
    <origin xyz="0.34 0 0" rpy="0 0 0" />
    <parent link="wrist" />
    <child link="tool_flange" />
    <axis xyz="1 0 0" />
    <limit effort="180" velocity="2.4" lower="-3.14159" upper="3.14159" />
    <dynamics damping="3" friction="0.8" />
    </joint>
  </robot>
