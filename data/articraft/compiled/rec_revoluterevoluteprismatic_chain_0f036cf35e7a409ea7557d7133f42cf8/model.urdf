  <joint name="support_to_upper" type="revolute">
    <origin xyz="0 0 0.8" rpy="0 0 0" />
    <parent link="rear_support" />
    <child link="upper_link" />
    <axis xyz="0 -1 0" />
    <limit effort="90" velocity="1.4" lower="-0.65" upper="0.95" />
    </joint>
  <joint name="upper_to_fore" type="revolute">
    <origin xyz="0.7 0 0" rpy="0 0 0" />
    <parent link="upper_link" />
    <child link="forelink" />
    <axis xyz="0 -1 0" />
    <limit effort="70" velocity="1.8" lower="-1.1" upper="1.15" />
    </joint>
