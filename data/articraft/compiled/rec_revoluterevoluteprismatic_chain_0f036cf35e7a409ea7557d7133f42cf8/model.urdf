    <origin xyz="0.62 0 0" rpy="0 0 0" />
    <parent link="forelink" />
    <child link="output_ram" />
    <axis xyz="1 0 0" />
    <limit effort="120" velocity="0.35" lower="0" upper="0.2" />
    </joint>
