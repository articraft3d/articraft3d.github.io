  <joint name="base_swivel" type="continuous">
    <origin xyz="0 0 0.053" rpy="0 0 0" />
    <parent link="base" />
    <child link="stand" />
    <axis xyz="0 0 1" />
    <limit effort="30" velocity="2" />
    </joint>
  <joint name="height_slide" type="prismatic">
    <origin xyz="0 0.045 0.34" rpy="0 0 0" />
    <parent link="stand" />
    <child link="height_stage" />
    <axis xyz="0 0 1" />
    <limit effort="120" velocity="0.25" lower="0" upper="0.18" />
    </joint>
  <joint name="screen_tilt" type="revolute">
    <origin xyz="0 -0.13 0.4" rpy="0 0 0" />
    <parent link="height_stage" />
    <child link="tilt_bracket" />
    <axis xyz="1 0 0" />
    <limit effort="18" velocity="1.5" lower="-0.25" upper="0.35" />
    </joint>
  <joint name="screen_roll" type="continuous">
    <parent link="tilt_bracket" />
    <child link="screen" />
    <axis xyz="0 1 0" />
    <limit effort="8" velocity="2" />
    </joint>
  <joint name="cable_door_hinge" type="revolute">
    <origin xyz="-0.0525 0.086 0.25" rpy="0 0 0" />
    <parent link="stand" />
    <child link="cable_door" />
    <axis xyz="0 0 1" />
    <limit effort="1.5" velocity="2" lower="0" upper="1.35" />
    </joint>
  </robot>
