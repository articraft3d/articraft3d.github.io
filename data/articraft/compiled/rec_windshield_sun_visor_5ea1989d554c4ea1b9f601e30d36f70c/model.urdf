  <joint name="bracket_to_clip" type="fixed">
    <origin xyz="0.502 0 0.025" rpy="0 0 0" />
    <parent link="roof_bracket" />
    <child link="retaining_clip" />
    </joint>
  <joint name="bracket_to_swivel" type="revolute">
    <parent link="roof_bracket" />
    <child link="swivel" />
    <axis xyz="0 0 1" />
    <limit effort="8" velocity="1" lower="0" upper="1.75" />
    </joint>
  <joint name="swivel_to_visor" type="revolute">
    <origin xyz="0 0 -0.035" rpy="0 0 0" />
    <parent link="swivel" />
    <child link="visor" />
    <axis xyz="1 0 0" />
    <limit effort="10" velocity="1.3" lower="0" upper="1.9" />
    </joint>
  <joint name="visor_to_mirror_cover" type="revolute">
    <origin xyz="0.145 -0.012 -0.076" rpy="0 0 0" />
    <parent link="visor" />
    <child link="mirror_cover" />
    <axis xyz="-1 0 0" />
    <limit effort="1" velocity="2" lower="0" upper="1.65" />
    </joint>
  <joint name="visor_to_extender" type="prismatic">
