  <joint name="bowl_twist_lock" type="revolute">
    <origin xyz="0 -0.1 0.093" rpy="0 0 0" />
    <parent link="base" />
    <child link="bowl" />
    <axis xyz="0 0 1" />
    <limit effort="18" velocity="1" lower="-0.26" upper="0.26" />
    </joint>
  <joint name="head_tilt" type="revolute">
    <origin xyz="0 0.094 0.334" rpy="0 0 0" />
    <parent link="base" />
    <child link="mixing_head" />
    <axis xyz="-1 0 0" />
    <limit effort="60" velocity="0.7" lower="0" upper="0.72" />
    </joint>
  <joint name="speed_slider" type="prismatic">
    <origin xyz="0.116 -0.115 0.03" rpy="0 0 0" />
    <parent link="mixing_head" />
    <child link="speed_lever" />
    <axis xyz="0 1 0" />
    <limit effort="3" velocity="0.08" lower="0" upper="0.045" />
    </joint>
  <joint name="beater_spin" type="continuous">
    <origin xyz="0 -0.194 -0.066" rpy="0 0 0" />
    <parent link="mixing_head" />
    <child link="beater_hub" />
    <axis xyz="0 0 -1" />
    <limit effort="8" velocity="18" />
    </joint>
  </robot>
