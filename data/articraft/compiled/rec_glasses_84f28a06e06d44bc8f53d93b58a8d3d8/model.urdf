<robot name="rectangular_eyeglasses">
  <material name="satin_black_acetate">
    <color rgba="0.01 0.01 0.012 1" />
    </material>
  <material name="faint_blue_lens">
    <color rgba="0.72 0.9 1 0.36" />
    </material>
  <link name="front_frame">
    <visual name="frame_shell">
      <geometry>
        <mesh filename="assets/meshes/front_frame_shell.obj" />
        </geometry>
      <material name="satin_black_acetate">
        <color rgba="0.01 0.01 0.012 1" />
        </material>
      </visual>
    <visual name="lens_0">
      <origin xyz="-0.035 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.048 0.0012 0.03" />
        </geometry>
      <material name="faint_blue_lens">
        <color rgba="0.72 0.9 1 0.36" />
        </material>
      </visual>
    <visual name="lens_1">
      <origin xyz="0.035 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.048 0.0012 0.03" />
        </geometry>
      <material name="faint_blue_lens">
        <color rgba="0.72 0.9 1 0.36" />
        </material>
      </visual>
    <collision name="frame_shell">
      <geometry>
        <mesh filename="assets/meshes/front_frame_shell.obj" />
        </geometry>
      </collision>
    <collision name="lens_0">
      <origin xyz="-0.035 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.048 0.0012 0.03" />
        </geometry>
      </collision>
    <collision name="lens_1">
      <origin xyz="0.035 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.048 0.0012 0.03" />
        </geometry>
      </collision>
    </link>
  <link name="temple_0">
    <visual name="arm_shell">
      <geometry>
        <mesh filename="assets/meshes/temple_0_shell.obj" />
        </geometry>
      <material name="satin_black_acetate">
        <color rgba="0.01 0.01 0.012 1" />
        </material>
      </visual>
    <collision name="arm_shell">
      <geometry>
        <mesh filename="assets/meshes/temple_0_shell.obj" />
        </geometry>
      </collision>
    </link>
  <link name="temple_1">
    <visual name="arm_shell">
      <geometry>
        <mesh filename="assets/meshes/temple_1_shell.obj" />
        </geometry>
      <material name="satin_black_acetate">
        <color rgba="0.01 0.01 0.012 1" />
        </material>
      </visual>
    <collision name="arm_shell">
      <geometry>
        <mesh filename="assets/meshes/temple_1_shell.obj" />
        </geometry>
      </collision>
    </link>
  <joint name="front_to_temple_0" type="revolute">
    <origin xyz="-0.066 0.0055 0.004" rpy="0 0 0" />
    <parent link="front_frame" />
    <child link="temple_0" />
    <axis xyz="0 0 -1" />
    <limit effort="0.5" velocity="2" lower="0" upper="1.75" />
    </joint>
  <joint name="front_to_temple_1" type="revolute">
    <origin xyz="0.066 0.0055 0.004" rpy="0 0 0" />
    <parent link="front_frame" />
    <child link="temple_1" />
    <axis xyz="0 0 1" />
    <limit effort="0.5" velocity="2" lower="0" upper="1.75" />
    </joint>
  </robot>
