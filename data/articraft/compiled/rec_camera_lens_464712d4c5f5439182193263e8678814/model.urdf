  <joint name="outer_to_zoom_ring" type="revolute">
    <parent link="outer_barrel" />
    <child link="zoom_ring" />
    <axis xyz="1 0 0" />
    <limit effort="1.5" velocity="2" lower="0" upper="1.91986" />
    </joint>
  <joint name="outer_to_inner_barrel" type="prismatic">
    <origin xyz="0.045 0 0" rpy="0 0 0" />
    <parent link="outer_barrel" />
    <child link="inner_barrel" />
    <axis xyz="1 0 0" />
    <limit effort="12" velocity="0.08" lower="0" upper="0.035" />
    </joint>
  <joint name="inner_to_focus_ring" type="revolute">
    <origin xyz="0.036 0 0" rpy="0 0 0" />
    <parent link="inner_barrel" />
    <child link="focus_ring" />
    <axis xyz="1 0 0" />
    <limit effort="0.8" velocity="2.5" lower="-1.65806" upper="1.65806" />
    </joint>
  </robot>
