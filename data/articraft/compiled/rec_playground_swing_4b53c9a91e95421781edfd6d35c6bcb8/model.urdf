    <visual name="hanger_tab_0">
      <origin xyz="-0.24 0 -0.055" rpy="0 0 0" />
      <geometry>
        <box size="0.035 0.02 0.09" />
        </geometry>
      <material name="galvanized_steel">
        <color rgba="0.56 0.59 0.6 1" />
        </material>
      </visual>
    <visual name="hanger_tab_1">
      <origin xyz="0.24 0 -0.055" rpy="0 0 0" />
      <geometry>
        <box size="0.035 0.02 0.09" />
        </geometry>
      <material name="galvanized_steel">
        <color rgba="0.56 0.59 0.6 1" />
        </material>
      </visual>
    </link>
  <joint name="beam_to_yoke" type="revolute">
    <parent link="beam" />
    <child link="yoke" />
    <axis xyz="1 0 0" />
    <limit effort="80" velocity="1.5" lower="-0.55" upper="0.55" />
    </joint>
  <joint name="yoke_to_tire" type="revolute">
    <origin xyz="0 0 -0.56" rpy="0 0 0" />
    <parent link="yoke" />
    <child link="tire" />
    <axis xyz="1 0 0" />
    <limit effort="45" velocity="1.8" lower="-0.7" upper="0.7" />
    </joint>
  </robot>
