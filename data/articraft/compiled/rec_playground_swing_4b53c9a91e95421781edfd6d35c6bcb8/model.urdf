        <box size="0.04 0.14 0.17" />
        </geometry>
      <material name="galvanized_steel">
        <color rgba="0.56 0.59 0.6 1" />
        </material>
      </visual>
    <visual name="pivot_cap_0">
      <origin xyz="-0.43 0 0" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.03" length="0.02" />
        </geometry>
      <material name="dark_pivot_steel">
        <color rgba="0.1 0.11 0.12 1" />
        </material>
      </visual>
    <visual name="pivot_cheek_1">
      <origin xyz="0.4 0 -0.005" rpy="0 0 0" />
      <geometry>
        <box size="0.04 0.14 0.17" />
        </geometry>
      <material name="galvanized_steel">
        <color rgba="0.56 0.59 0.6 1" />
        </material>
      </visual>
    <visual name="pivot_cap_1">
      <origin xyz="0.43 0 0" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.03" length="0.02" />
        </geometry>
      <material name="dark_pivot_steel">
        <color rgba="0.1 0.11 0.12 1" />
        </material>
      </visual>
    </link>
  <link name="yoke">
    <visual name="top_barrel">
      <origin xyz="0 0 0" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.035" length="0.76" />
        </geometry>
      <material name="dark_pivot_steel">
        <color rgba="0.1 0.11 0.12 1" />
        </material>
      </visual>
    <visual name="rigid_link_0">
      <origin xyz="-0.3 0 -0.285" rpy="0 0 0" />
      <geometry>
        <box size="0.045 0.028 0.5" />
        </geometry>
      <material name="galvanized_steel">
        <color rgba="0.56 0.59 0.6 1" />
        </material>
      </visual>
    <visual name="rigid_link_1">
      <origin xyz="0.3 0 -0.285" rpy="0 0 0" />
      <geometry>
        <box size="0.045 0.028 0.5" />
        </geometry>
      <material name="galvanized_steel">
        <color rgba="0.56 0.59 0.6 1" />
        </material>
      </visual>
    <visual name="lower_eye_0">
      <origin xyz="-0.3 0 -0.56" rpy="0 1.5708 0" />
      <geometry>
        <mesh filename="assets/meshes/lower_hanger_eye.obj" />
        </geometry>
      <material name="galvanized_steel">
        <color rgba="0.56 0.59 0.6 1" />
        </material>
      </visual>
    <visual name="lower_eye_1">
      <origin xyz="0.3 0 -0.56" rpy="0 1.5708 0" />
      <geometry>
        <mesh filename="assets/meshes/lower_hanger_eye.obj" />
        </geometry>
      <material name="galvanized_steel">
        <color rgba="0.56 0.59 0.6 1" />
        </material>
      </visual>
    </link>
  <link name="tire">
    <visual name="tire_ring">
      <origin xyz="0 0 -0.13" rpy="0 -1.5708 0" />
      <geometry>
        <mesh filename="assets/meshes/horizontal_tire_seat.obj" />
        </geometry>
      <material name="black_rubber">
        <color rgba="0.015 0.014 0.012 1" />
        </material>
      </visual>
    <visual name="axle">
      <origin xyz="0 0 0" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.027" length="0.76" />
        </geometry>
      <material name="dark_pivot_steel">
        <color rgba="0.1 0.11 0.12 1" />
        </material>
