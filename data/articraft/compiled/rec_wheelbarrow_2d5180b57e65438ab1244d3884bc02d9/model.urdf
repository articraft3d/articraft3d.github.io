<robot name="field_service_wheelbarrow">
  <material name="worn_orange_paint">
    <color rgba="0.86 0.29 0.08 1" />
    </material>
  <material name="black_powdercoated_steel">
    <color rgba="0.03 0.035 0.035 1" />
    </material>
  <material name="chunky_black_rubber">
    <color rgba="0.005 0.005 0.004 1" />
    </material>
  <material name="galvanized_service_metal">
    <color rgba="0.58 0.6 0.58 1" />
    </material>
  <material name="replaceable_grip_rubber">
    <color rgba="0.015 0.012 0.01 1" />
    </material>
  <material name="dark_bolt_heads">
    <color rgba="0.02 0.02 0.018 1" />
    </material>
  <link name="chassis">
    <visual name="tray_shell">
      <geometry>
        <mesh filename="assets/meshes/hollow_tray.obj" />
