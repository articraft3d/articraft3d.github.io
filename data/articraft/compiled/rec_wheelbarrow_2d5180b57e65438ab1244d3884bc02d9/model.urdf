    </link>
  <link name="front_wheel">
    <visual name="tire">
      <origin xyz="0 0 0" rpy="0 0 1.5708" />
      <geometry>
        <mesh filename="assets/meshes/tire.obj" />
        </geometry>
      <material name="chunky_black_rubber">
        <color rgba="0.005 0.005 0.004 1" />
        </material>
      </visual>
    <visual name="rim">
      <origin xyz="0 0 0" rpy="0 0 1.5708" />
      <geometry>
        <mesh filename="assets/meshes/rim.obj" />
        </geometry>
      <material name="galvanized_service_metal">
        <color rgba="0.58 0.6 0.58 1" />
