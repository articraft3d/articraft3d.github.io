    <visual name="bolt_head_1_1">
      <geometry>
        <mesh filename="assets/meshes/bolt_head_1_1.obj" />
        </geometry>
      <material name="dark_bolt_heads">
        <color rgba="0.02 0.02 0.018 1" />
