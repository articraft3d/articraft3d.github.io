      <geometry>
        <mesh filename="assets/meshes/rim.obj" />
        </geometry>
      </collision>
    </link>
  <joint name="wheel_axle" type="continuous">
    <origin xyz="-0.71 0 0.25" rpy="0 0 0" />
    <parent link="chassis" />
    <child link="front_wheel" />
    <axis xyz="0 1 0" />
    <limit effort="45" velocity="18" />
    </joint>
  </robot>
