    <origin xyz="0.04 0 0.018" rpy="0 0 0" />
    <parent link="clamp_ring" />
    <child link="binder_lever" />
    <axis xyz="0 -1 0" />
    <limit effort="25" velocity="4" lower="0" upper="1.25" />
    </joint>
