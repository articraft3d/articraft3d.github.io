  <joint name="saddle_perch_to_front_bolt" type="continuous">
    <origin xyz="-0.024 0 0.047" rpy="0 0 0" />
    <parent link="saddle_perch" />
    <child link="front_bolt" />
    <axis xyz="0 0 1" />
    <limit effort="4" velocity="8" />
    </joint>
  <joint name="saddle_perch_to_rear_bolt" type="continuous">
    <origin xyz="0.024 0 0.047" rpy="0 0 0" />
    <parent link="saddle_perch" />
    <child link="rear_bolt" />
    <axis xyz="0 0 1" />
    <limit effort="4" velocity="8" />
    </joint>
  <joint name="frame_sleeve_to_clamp_ring" type="fixed">
    <origin xyz="0 0 0.206" rpy="0 0 0" />
    <parent link="frame_sleeve" />
    <child link="clamp_ring" />
    </joint>
  <joint name="clamp_ring_to_outer_tube" type="fixed">
    <origin xyz="0 0 -0.166" rpy="0 0 0" />
    <parent link="clamp_ring" />
    <child link="outer_tube" />
    </joint>
  <joint name="outer_tube_to_inner_tube" type="prismatic">
    <origin xyz="0 0 0.436" rpy="0 0 0" />
    <parent link="outer_tube" />
    <child link="inner_tube" />
    <axis xyz="0 0 1" />
