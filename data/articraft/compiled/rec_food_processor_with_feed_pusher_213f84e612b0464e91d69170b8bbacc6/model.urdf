  <joint name="bowl_twist" type="continuous">
    <origin xyz="0 0 0.14" rpy="0 0 0" />
    <parent link="base" />
    <child link="bowl" />
    <axis xyz="0 0 1" />
    <limit effort="10" velocity="1.2" />
    </joint>
  <joint name="blade_spin" type="continuous">
    <origin xyz="0 0 0.198" rpy="0 0 0" />
    <parent link="base" />
    <child link="blade_hub" />
    <axis xyz="0 0 1" />
    <limit effort="3" velocity="50" />
    </joint>
