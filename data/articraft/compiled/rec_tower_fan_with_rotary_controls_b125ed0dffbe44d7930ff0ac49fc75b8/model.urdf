  <joint name="base_to_tower" type="revolute">
    <origin xyz="0 0 0.075" rpy="0 0 0" />
    <parent link="pedestal_base" />
    <child link="tower_body" />
    <axis xyz="0 0 1" />
    <limit effort="12" velocity="1.2" lower="-0.85" upper="0.85" />
    </joint>
  <joint name="tower_to_blower" type="continuous">
    <origin xyz="0 0 0.465" rpy="0 0 0" />
    <parent link="tower_body" />
    <child link="blower_wheel" />
    <axis xyz="0 0 1" />
    <limit effort="1.2" velocity="45" />
    </joint>
  <joint name="tower_to_speed_knob" type="continuous">
    <origin xyz="-0.048 -0.018 0.887" rpy="0 0 0" />
    <parent link="tower_body" />
    <child link="speed_knob" />
    <axis xyz="0 0 1" />
    <limit effort="0.3" velocity="4" />
    </joint>
  <joint name="tower_to_timer_knob" type="continuous">
    <origin xyz="0.004 -0.018 0.887" rpy="0 0 0" />
    <parent link="tower_body" />
    <child link="timer_knob" />
    <axis xyz="0 0 1" />
    <limit effort="0.3" velocity="4" />
    </joint>
  <joint name="tower_to_osc_button" type="prismatic">
    <origin xyz="0.06 -0.018 0.887" rpy="0 0 0" />
    <parent link="tower_body" />
    <child link="osc_button" />
    <axis xyz="0 0 -1" />
    <limit effort="2" velocity="0.08" lower="0" upper="0.004" />
    </joint>
  </robot>
