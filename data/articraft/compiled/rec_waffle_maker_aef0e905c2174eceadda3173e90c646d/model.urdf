    <color rgba="0.005 0.005 0.005 1" />
    </material>
  <material name="amber_indicator_lens">
    <color rgba="1 0.46 0.05 1" />
    </material>
  <material name="white_marking">
    <color rgba="0.96 0.94 0.86 1" />
    </material>
  <link name="base">
