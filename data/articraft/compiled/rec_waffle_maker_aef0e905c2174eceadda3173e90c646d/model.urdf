  <link name="browning_knob">
    <visual name="knob_cap">
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <mesh filename="assets/meshes/browning_knob.obj" />
        </geometry>
      <material name="satin_black_plastic">
        <color rgba="0.015 0.014 0.013 1" />
