      </visual>
    <visual name="knob_pointer">
      <origin xyz="0 -0.0284 0.01" rpy="0 0 0" />
      <geometry>
        <box size="0.004 0.0012 0.021" />
        </geometry>
      <material name="white_marking">
        <color rgba="0.96 0.94 0.86 1" />
        </material>
      </visual>
    </link>
  <joint name="base_to_upper" type="revolute">
    <origin xyz="0.145 0 0.118" rpy="0 0 0" />
    <parent link="base" />
    <child link="upper_plate" />
    <axis xyz="0 1 0" />
    <limit effort="8" velocity="2" lower="0" upper="1.35" />
    </joint>
  <joint name="base_to_knob" type="continuous">
    <origin xyz="-0.035 -0.1295 0.055" rpy="0 0 0" />
    <parent link="base" />
    <child link="browning_knob" />
    <axis xyz="0 -1 0" />
    <limit effort="1" velocity="6" />
    </joint>
  </robot>
