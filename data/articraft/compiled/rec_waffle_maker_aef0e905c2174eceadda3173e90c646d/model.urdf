      <geometry>
        <mesh filename="assets/meshes/upper_shell.obj" />
        </geometry>
      <material name="satin_black_plastic">
        <color rgba="0.015 0.014 0.013 1" />
        </material>
      </visual>
    <visual name="upper_plate_grid">
      <geometry>
        <mesh filename="assets/meshes/upper_plate_grid.obj" />
        </geometry>
      <material name="seasoned_cast_aluminum">
        <color rgba="0.025 0.024 0.022 1" />
        </material>
      </visual>
    <visual name="moving_hinge_knuckle">
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.01" length="0.11" />
        </geometry>
      <material name="brushed_warm_steel">
        <color rgba="0.62 0.57 0.5 1" />
        </material>
      </visual>
    <visual name="hinge_leaf">
      <origin xyz="-0.01 0 0.006" rpy="0 0 0" />
      <geometry>
        <box size="0.018 0.07 0.024" />
        </geometry>
      <material name="satin_black_plastic">
        <color rgba="0.015 0.014 0.013 1" />
        </material>
      </visual>
    <visual name="front_handle">
      <geometry>
        <mesh filename="assets/meshes/front_handle.obj" />
        </geometry>
      <material name="satin_black_plastic">
        <color rgba="0.015 0.014 0.013 1" />
