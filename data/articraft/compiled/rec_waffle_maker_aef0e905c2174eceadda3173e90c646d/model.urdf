        </geometry>
      <material name="satin_black_plastic">
        <color rgba="0.015 0.014 0.013 1" />
        </material>
      </visual>
    <visual name="fixed_hinge_knuckle_1">
      <origin xyz="0.145 0.081 0.118" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.01" length="0.052" />
        </geometry>
      <material name="brushed_warm_steel">
        <color rgba="0.62 0.57 0.5 1" />
        </material>
      </visual>
    <visual name="foot_0">
      <origin xyz="-0.115 -0.075 0.0025" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.017" length="0.012" />
