<robot name="compact_gimbal_cube">
  <material name="black_hard_anodized">
    <color rgba="0.025 0.027 0.03 1" />
    </material>
  <material name="graphite_bearing">
    <color rgba="0.18 0.18 0.17 1" />
    </material>
  <material name="satin_aluminum">
    <color rgba="0.72 0.7 0.64 1" />
    </material>
  <material name="brushed_steel">
    <color rgba="0.58 0.6 0.6 1" />
    </material>
  <material name="bronze_retainer">
    <color rgba="0.74 0.46 0.18 1" />
    </material>
  <link name="roll_carrier">
    <visual name="bearing_saddle">
      <geometry>
        <mesh filename="assets/meshes/roll_carrier_body.obj" />
        </geometry>
      <material name="graphite_bearing">
        <color rgba="0.18 0.18 0.17 1" />
        </material>
      </visual>
    <visual name="base_dowel">
      <origin xyz="-0.072 0 -0.112" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.0045" length="0.142" />
        </geometry>
      <material name="brushed_steel">
        <color rgba="0.58 0.6 0.6 1" />
        </material>
      </visual>
    <collision name="bearing_saddle">
      <geometry>
        <mesh filename="assets/meshes/roll_carrier_body.obj" />
        </geometry>
      </collision>
    <collision name="base_dowel">
      <origin xyz="-0.072 0 -0.112" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.0045" length="0.142" />
        </geometry>
      </collision>
    </link>
  <link name="outer_frame">
    <visual name="frame_body">
      <geometry>
        <mesh filename="assets/meshes/outer_frame_body.obj" />
        </geometry>
      <material name="black_hard_anodized">
        <color rgba="0.025 0.027 0.03 1" />
        </material>
      </visual>
    <visual name="roll_retainer">
      <geometry>
        <mesh filename="assets/meshes/roll_retainer.obj" />
        </geometry>
      <material name="bronze_retainer">
        <color rgba="0.74 0.46 0.18 1" />
        </material>
      </visual>
    <visual name="pitch_bushing_0">
      <geometry>
        <mesh filename="assets/meshes/pitch_bushing_0.obj" />
        </geometry>
      <material name="brushed_steel">
        <color rgba="0.58 0.6 0.6 1" />
        </material>
      </visual>
    <visual name="pitch_bushing_1">
      <geometry>
        <mesh filename="assets/meshes/pitch_bushing_1.obj" />
        </geometry>
      <material name="brushed_steel">
        <color rgba="0.58 0.6 0.6 1" />
        </material>
      </visual>
    <collision name="frame_body">
      <geometry>
        <mesh filename="assets/meshes/outer_frame_body.obj" />
        </geometry>
      </collision>
    <collision name="roll_retainer">
      <geometry>
        <mesh filename="assets/meshes/roll_retainer.obj" />
        </geometry>
      </collision>
    <collision name="pitch_bushing_0">
      <geometry>
        <mesh filename="assets/meshes/pitch_bushing_0.obj" />
        </geometry>
      </collision>
    <collision name="pitch_bushing_1">
      <geometry>
        <mesh filename="assets/meshes/pitch_bushing_1.obj" />
        </geometry>
      </collision>
    </link>
  <link name="inner_cradle">
    <visual name="barrel_cradle">
      <geometry>
        <mesh filename="assets/meshes/inner_barrel_body.obj" />
        </geometry>
      <material name="satin_aluminum">
        <color rgba="0.72 0.7 0.64 1" />
        </material>
      </visual>
    <visual name="center_flange">
      <geometry>
        <mesh filename="assets/meshes/center_flange.obj" />
        </geometry>
      <material name="brushed_steel">
        <color rgba="0.58 0.6 0.6 1" />
        </material>
      </visual>
    <visual name="trunnion_pin">
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.004" length="0.17" />
        </geometry>
      <material name="bronze_retainer">
        <color rgba="0.74 0.46 0.18 1" />
        </material>
      </visual>
    <collision name="barrel_cradle">
      <geometry>
        <mesh filename="assets/meshes/inner_barrel_body.obj" />
        </geometry>
      </collision>
    <collision name="center_flange">
      <geometry>
        <mesh filename="assets/meshes/center_flange.obj" />
        </geometry>
      </collision>
    <collision name="trunnion_pin">
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.004" length="0.17" />
        </geometry>
      </collision>
    </link>
  <joint name="roll_axis" type="revolute">
    <parent link="roll_carrier" />
    <child link="outer_frame" />
    <axis xyz="1 0 0" />
    <limit effort="18" velocity="2.2" lower="-0.7" upper="0.7" />
    </joint>
  <joint name="pitch_axis" type="revolute">
    <parent link="outer_frame" />
    <child link="inner_cradle" />
    <axis xyz="0 1 0" />
    <limit effort="10" velocity="2.5" lower="-0.52" upper="0.52" />
    </joint>
  </robot>
