    <parent link="lower_shell" />
    <child link="lid" />
    <axis xyz="0 0 1" />
    <limit effort="0.8" velocity="5" lower="-1.65" upper="0.35" />
    </joint>
  <joint name="wheel_axle" type="continuous">
    <origin xyz="0.0068 0 0.051" rpy="0 0 0" />
    <parent link="insert" />
    <child link="spark_wheel" />
    <axis xyz="0 1 0" />
    <limit effort="0.05" velocity="40" />
    </joint>
  </robot>
