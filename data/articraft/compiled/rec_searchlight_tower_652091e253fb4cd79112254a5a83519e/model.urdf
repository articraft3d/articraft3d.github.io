  <joint name="tower_to_pan" type="revolute">
    <origin xyz="0 0 2" rpy="0 0 0" />
    <parent link="tower" />
    <child link="pan_stage" />
    <axis xyz="0 0 1" />
    <limit effort="80" velocity="1.2" lower="-3.14159" upper="3.14159" />
    </joint>
  <joint name="pan_to_lamp" type="revolute">
    <origin xyz="0 0 0.59" rpy="0 0 0" />
    <parent link="pan_stage" />
    <child link="lamp_head" />
    <axis xyz="0 -1 0" />
    <limit effort="45" velocity="1" lower="-0.5" upper="0.9" />
    </joint>
  </robot>
