  <joint name="height_slide" type="prismatic">
    <origin xyz="0 0 0.365" rpy="0 0 0" />
    <parent link="base" />
    <child link="lift_stage" />
    <axis xyz="0 0 1" />
    <limit effort="850" velocity="0.22" lower="0" upper="0.2" />
    </joint>
  <joint name="seat_swivel" type="continuous">
    <origin xyz="0 0 0.355" rpy="0 0 0" />
    <parent link="lift_stage" />
    <child link="seat" />
    <axis xyz="0 0 1" />
    <limit effort="45" velocity="3.2" />
    </joint>
  <joint name="lever_pivot" type="revolute">
