  <joint name="bottom_bracket_axle" type="continuous">
    <parent link="bottom_bracket_shell" />
    <child link="crankset" />
    <axis xyz="1 0 0" />
    <limit effort="120" velocity="20" />
    <dynamics damping="0.02" friction="0.01" />
    </joint>
  <joint name="right_pedal_axle" type="continuous">
    <origin xyz="0.108 0 -0.17" rpy="0 0 0" />
    <parent link="crankset" />
    <child link="right_pedal" />
    <axis xyz="1 0 0" />
    <limit effort="20" velocity="25" />
    <dynamics damping="0.01" friction="0.004" />
    </joint>
  <joint name="left_pedal_axle" type="continuous">
    <origin xyz="-0.108 0 0.17" rpy="0 0 0" />
