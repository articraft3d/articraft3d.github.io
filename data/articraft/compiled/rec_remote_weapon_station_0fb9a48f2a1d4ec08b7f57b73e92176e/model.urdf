  <joint name="base_azimuth" type="continuous">
    <origin xyz="0 0 0.7" rpy="0 0 0" />
    <parent link="pedestal" />
    <child link="azimuth_frame" />
    <axis xyz="0 0 1" />
    <limit effort="260" velocity="1.4" />
    </joint>
  <joint name="cradle_elevation" type="revolute">
    <origin xyz="0 0 0.34" rpy="0 0 0" />
    <parent link="azimuth_frame" />
    <child link="gun_cradle" />
    <axis xyz="0 -1 0" />
    <limit effort="180" velocity="1" lower="-0.25" upper="0.45" />
    </joint>
  <joint name="sight_tilt" type="revolute">
    <origin xyz="0.11 -0.43 0.47" rpy="0 0 0" />
